# Maintainer: Thorch contributors

pkgname=thorch-firmware-rocknix
pkgver=1
pkgrel=7
pkgdesc='Public ROCKNIX SM8550 firmware and runtime artifacts packaged for Thorch'
arch=(aarch64)
url='https://github.com/ROCKNIX/distribution'
license=(custom)
depends=(expat gcc-libs glibc libdrm libx11 libxcb libxshmfence vulkan-icd-loader wayland zlib zstd)
makedepends=(patchelf python)
provides=(
  vulkan-driver
  linux-firmware
  linux-firmware-amdgpu
  linux-firmware-atheros
  linux-firmware-broadcom
  linux-firmware-cirrus
  linux-firmware-intel
  linux-firmware-liquidio
  linux-firmware-marvell
  linux-firmware-mediatek
  linux-firmware-mellanox
  linux-firmware-nfp
  linux-firmware-nvidia
  linux-firmware-other
  linux-firmware-qcom
  linux-firmware-qlogic
  linux-firmware-radeon
  linux-firmware-realtek
  linux-firmware-whence
)
conflicts=(
  linux-firmware
  linux-firmware-amdgpu
  linux-firmware-atheros
  linux-firmware-broadcom
  linux-firmware-cirrus
  linux-firmware-intel
  linux-firmware-liquidio
  linux-firmware-marvell
  linux-firmware-mediatek
  linux-firmware-mellanox
  linux-firmware-nfp
  linux-firmware-nvidia
  linux-firmware-other
  linux-firmware-qcom
  linux-firmware-qlogic
  linux-firmware-radeon
  linux-firmware-realtek
  linux-firmware-whence
)
replaces=(
  linux-firmware
  linux-firmware-amdgpu
  linux-firmware-atheros
  linux-firmware-broadcom
  linux-firmware-cirrus
  linux-firmware-intel
  linux-firmware-liquidio
  linux-firmware-marvell
  linux-firmware-mediatek
  linux-firmware-mellanox
  linux-firmware-nfp
  linux-firmware-nvidia
  linux-firmware-other
  linux-firmware-qcom
  linux-firmware-qlogic
  linux-firmware-radeon
  linux-firmware-realtek
  linux-firmware-whence
)
options=(!strip)

_firmware_dir="${THORCH_FIRMWARE_DIR:-${startdir}/../../vendor/rocknix-sm8550/firmware}"
_rocknix_kernel_dir="${THORCH_ROCKNIX_KERNEL_DIR:-${startdir}/../../vendor/rocknix-kernel}"

package() {
  if [[ ! -d "${_firmware_dir}/qcom/sm8550/ayn/thor" ]]; then
    cat >&2 <<EOF
Missing synced ROCKNIX firmware at:
  ${_firmware_dir}

Run from the repository root:
  ./scripts/sync-rocknix-sources.sh --ref <pinned ROCKNIX commit> --with-firmware
EOF
    exit 1
  fi

  install -d "${pkgdir}/usr/lib/firmware"
  cp -a "${_firmware_dir}/." "${pkgdir}/usr/lib/firmware/"
  if [[ -d "${_rocknix_kernel_dir}/usr/lib/firmware" ]]; then
    cp -a "${_rocknix_kernel_dir}/usr/lib/firmware/." "${pkgdir}/usr/lib/firmware/"
  fi
  if [[ ! -e "${pkgdir}/usr/lib/firmware/qcom/sm8550/AYN-Thor-tplg.bin" ]]; then
    ln -s AYN-Odin2-tplg.bin "${pkgdir}/usr/lib/firmware/qcom/sm8550/AYN-Thor-tplg.bin"
  fi
  for firmware in \
    qcom/a740_sqe.fw \
    qcom/gmu_gen70200.bin \
    qcom/sm8550/a740_zap.mbn; do
    if [[ ! -f "${pkgdir}/usr/lib/firmware/${firmware}" ]]; then
      cat >&2 <<EOF
Missing ROCKNIX Adreno firmware:
  usr/lib/firmware/${firmware}

Re-import kernel artifacts from a ROCKNIX image with /SYSTEM:
  ./scripts/sync-rocknix-kernel.sh
EOF
      exit 1
    fi
  done

  if [[ ! -f "${_rocknix_kernel_dir}/usr/lib/libvulkan_freedreno.so" ]]; then
    cat >&2 <<EOF
Missing ROCKNIX runtime artifacts at:
  ${_rocknix_kernel_dir}

Expected files imported from ROCKNIX /SYSTEM:
  usr/lib/libvulkan_freedreno.so
  usr/lib/libdisplay-info.so.0.2.0
  usr/share/fex-emu/libvulkan_freedreno.so
  usr/share/vulkan/icd.d/freedreno_icd.json

Run from the repository root:
  ./scripts/sync-rocknix-kernel.sh
EOF
    exit 1
  fi

  install -Dm755 "${_rocknix_kernel_dir}/usr/lib/libvulkan_freedreno.so" \
    "${pkgdir}/usr/lib/thorch/freedreno/libvulkan_freedreno.so"
  install -Dm755 "${_rocknix_kernel_dir}/usr/lib/libdisplay-info.so.0.2.0" \
    "${pkgdir}/usr/lib/thorch/freedreno/libdisplay-info.so.0.2.0"
  ln -s libdisplay-info.so.0.2.0 \
    "${pkgdir}/usr/lib/thorch/freedreno/libdisplay-info.so.2"
  patchelf --set-rpath '$ORIGIN' \
    "${pkgdir}/usr/lib/thorch/freedreno/libvulkan_freedreno.so"
  install -Dm755 "${_rocknix_kernel_dir}/usr/share/fex-emu/libvulkan_freedreno.so" \
    "${pkgdir}/usr/share/fex-emu/libvulkan_freedreno.so"
  python - \
    "${_rocknix_kernel_dir}/usr/share/vulkan/icd.d/freedreno_icd.json" \
    "${pkgdir}/usr/share/vulkan/icd.d/thorch_freedreno_icd.json" <<'PY'
import json
import pathlib
import sys

source = pathlib.Path(sys.argv[1])
destination = pathlib.Path(sys.argv[2])
data = json.loads(source.read_text(encoding="utf-8"))
icd = data.get("ICD")
if not isinstance(icd, dict) or not isinstance(icd.get("library_path"), str):
    raise SystemExit(f"invalid Vulkan ICD manifest: {source}")
icd["library_path"] = "/usr/lib/thorch/freedreno/libvulkan_freedreno.so"
destination.parent.mkdir(parents=True, exist_ok=True)
destination.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
PY

  install -d "${pkgdir}/usr/share/licenses/${pkgname}"
  if [[ -f "${_firmware_dir}/THORCH_FIRMWARE_PROVENANCE" ]]; then
    install -Dm644 "${_firmware_dir}/THORCH_FIRMWARE_PROVENANCE" \
      "${pkgdir}/usr/share/licenses/${pkgname}/PROVENANCE"
  else
    cat > "${pkgdir}/usr/share/licenses/${pkgname}/PROVENANCE" <<'EOF'
Firmware files are sourced from the public ROCKNIX distribution repository:
https://github.com/ROCKNIX/distribution
EOF
  fi
  if [[ -f "${_rocknix_kernel_dir}/PROVENANCE" ]]; then
    install -Dm644 "${_rocknix_kernel_dir}/PROVENANCE" \
      "${pkgdir}/usr/share/licenses/${pkgname}/ROCKNIX-RUNTIME-PROVENANCE"
  fi
}
