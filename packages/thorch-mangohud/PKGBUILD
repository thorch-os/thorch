# Maintainer: Thorch contributors

pkgname=thorch-mangohud
pkgver=0.8.3_rocknix
pkgrel=7
_commit=330c42a5956e005a4d102473f5782bb0e3d94b6f
_imgui_ver=1.91.6
_implot_ver=0.16
_spdlog_ver=1.14.1
_vulkan_headers_ver=1.4.346
_vulkan_utility_libraries_ver=1.4.346
pkgdesc='MangoHud with ROCKNIX Qualcomm GPU and battery patches plus config'
arch=(aarch64)
url='https://github.com/flightlessmango/MangoHud'
license=(MIT)
depends=(
  dbus
  gcc-libs
  glfw
  glibc
  libx11
  libxcb
  mesa
  python
  vulkan-icd-loader
  wayland
)
makedepends=(
  cmake
  fmt
  git
  glslang
  libxkbcommon
  libxrandr
  meson
  ninja
  python-mako
  spdlog
  vulkan-headers
  wayland-protocols
)
provides=(mangohud)
conflicts=(mangohud)
source=(
  "https://github.com/flightlessmango/MangoHud/archive/${_commit}.tar.gz"
  "imgui-${_imgui_ver}.tar.gz::https://github.com/ocornut/imgui/archive/refs/tags/v${_imgui_ver}.tar.gz"
  "imgui_${_imgui_ver}-3_patch.zip::https://wrapdb.mesonbuild.com/v2/imgui_${_imgui_ver}-3/get_patch"
  "implot-${_implot_ver}.zip::https://github.com/epezent/implot/archive/refs/tags/v${_implot_ver}.zip"
  "implot_${_implot_ver}-1_patch.zip::https://wrapdb.mesonbuild.com/v2/implot_${_implot_ver}-1/get_patch"
  "spdlog-${_spdlog_ver}.tar.gz::https://github.com/gabime/spdlog/archive/refs/tags/v${_spdlog_ver}.tar.gz"
  "spdlog_${_spdlog_ver}-1_patch.zip::https://wrapdb.mesonbuild.com/v2/spdlog_${_spdlog_ver}-1/get_patch"
  "vulkan-headers-${_vulkan_headers_ver}.tar.gz::https://github.com/KhronosGroup/Vulkan-Headers/archive/v${_vulkan_headers_ver}.tar.gz"
  "vulkan-utility-libraries-${_vulkan_utility_libraries_ver}.tar.gz::https://github.com/KhronosGroup/Vulkan-Utility-Libraries/archive/v${_vulkan_utility_libraries_ver}.tar.gz"
  "qualcomm-battery-power-now.patch"
)
b2sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)
backup=(etc/MangoHud.conf)

prepare() {
  cd "MangoHud-${_commit}"
  patch -Np1 -i "${startdir}/sm8550-gpu.patch"
  patch -Np1 -i "${startdir}/qualcomm-battery-power-now.patch"
  cp -a subprojects/packagefiles/vulkan-headers/. "${srcdir}/Vulkan-Headers-${_vulkan_headers_ver}/"
  cp -a subprojects/packagefiles/vulkan-utility-libraries/. "${srcdir}/Vulkan-Utility-Libraries-${_vulkan_utility_libraries_ver}/"
  ln -s "${srcdir}/imgui-${_imgui_ver}" subprojects/
  ln -s "${srcdir}/implot-${_implot_ver}" subprojects/
  ln -s "${srcdir}/spdlog-${_spdlog_ver}" subprojects/
  ln -s "${srcdir}/Vulkan-Headers-${_vulkan_headers_ver}" subprojects/
  ln -s "${srcdir}/Vulkan-Utility-Libraries-${_vulkan_utility_libraries_ver}" subprojects/
}

build() {
  arch-meson "MangoHud-${_commit}" build \
    -Dwith_xnvctrl=disabled \
    -Dwith_x11=enabled \
    -Dwith_wayland=enabled \
    -Dtests=disabled \
    -Dmangoplot=disabled \
    -Dmangoapp=true
  meson compile -C build
}

package() {
  DESTDIR="${pkgdir}" meson install -C build
  local rocknix_config="${THORCH_ROCKNIX_DIR:?THORCH_ROCKNIX_DIR is required}/packages/apps/mangohud/config/MangoHud.conf"
  [[ -f "${rocknix_config}" ]] || { printf 'missing ROCKNIX MangoHud config: %s\n' "${rocknix_config}" >&2; exit 1; }
  install -Dm644 "${rocknix_config}" "${pkgdir}/etc/MangoHud.conf"
  install -Dm644 "${rocknix_config}" "${pkgdir}/usr/share/thorch/mangohud/MangoHud.conf"
  sed -i 's/^# battery_time$/battery_time/' "${pkgdir}/etc/MangoHud.conf" "${pkgdir}/usr/share/thorch/mangohud/MangoHud.conf"
  install -Dm644 "MangoHud-${_commit}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
