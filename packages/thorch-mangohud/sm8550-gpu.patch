Subject: [PATCH] SM8550 GPU

Adapted for the MangoHud commit packaged by Thorch, where the MSM DRM
module identifier is "msm".
---
 src/gpu_fdinfo.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/gpu_fdinfo.cpp b/src/gpu_fdinfo.cpp
index 7b6f776d..f08f8a36 100644
--- a/src/gpu_fdinfo.cpp
+++ b/src/gpu_fdinfo.cpp
@@ -192,7 +192,7 @@ void GPU_fdinfo::find_hwmon_sensors()
     std::string hwmon;
 
     if (module == "msm")
-        hwmon = find_hwmon_sensor_dir("gpu");
+        hwmon = find_hwmon_sensor_dir("gpuss_0_thermal");
     else if (module == "panfrost" || module == "panthor")
         hwmon = find_hwmon_sensor_dir("gpu_thermal");
     else
@@ -655,7 +655,7 @@ float GPU_fdinfo::amdgpu_helper_get_proc_vram() {
 }
 
