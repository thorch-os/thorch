# Maintainer: Thorch contributors

pkgname=thorch-bsp
pkgver=1
pkgrel=19
pkgdesc='Thorch AYN Thor boot and board support package'
arch=(aarch64)
url='https://github.com/ROCKNIX/distribution'
license=(GPL-2.0-only GPL-2.0-or-later BSD-3-Clause custom)
depends=(android-tools bash coreutils dnsmasq dosfstools e2fsprogs file findutils grep gzip iproute2 iw kmod mkinitcpio mtools networkmanager openssh procps-ng python rfkill sudo systemd util-linux wireless-regdb zram-generator)
makedepends=(rust)
backup=(etc/thorch/hardware.conf etc/thorch/inputd.conf)
install=thorch-bsp.install
source=()
sha256sums=()

build() {
  rustc --test "${startdir}/inputd/thorch-inputd.rs" \
    --edition=2021 \
    -C opt-level=0 \
    -o "${srcdir}/thorch-inputd-tests"
  "${srcdir}/thorch-inputd-tests" --test-threads=1

  rustc "${startdir}/inputd/thorch-inputd.rs" \
    --edition=2021 \
    -C opt-level=2 \
    -o "${srcdir}/thorch-inputd"
}

package() {
  cd "${startdir}/payload"
  cp -a . "${pkgdir}/"
  find "${pkgdir}" -type d -name __pycache__ -prune -exec rm -rf {} +

  install -d "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550"
  ln -sf ../../AYN/Odin2/AYN-Odin2.conf \
    "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550/AYN-Odin2.conf"
  ln -sf ../../AYN/Odin2/AYN-Odin2.conf \
    "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550/ayn-AYNOdin2-.conf"
  ln -sf ../../AYN/Odin2/AYN-Odin2.conf \
    "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550/SM8550-AYN.conf"
  ln -sf ../../AYN/Thor/AYN-Thor.conf \
    "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550/AYN-Thor.conf"
  ln -sf ../../AYN/Thor/AYN-Thor.conf \
    "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550/AYNThor.conf"
  ln -sf ../../AYN/Thor/AYN-Thor.conf \
    "${pkgdir}/usr/share/alsa/ucm2/conf.d/sm8550/ayn-AYNThor-.conf"
  install -d "${pkgdir}/usr/share/alsa/ucm2/AYNThor" \
    "${pkgdir}/usr/share/alsa/ucm2/ayn-AYNThor-"
  ln -sf ../AYN/Thor/AYN-Thor.conf \
    "${pkgdir}/usr/share/alsa/ucm2/AYNThor/AYNThor.conf"
  ln -sf ../AYN/Thor/AYN-Thor.conf \
    "${pkgdir}/usr/share/alsa/ucm2/ayn-AYNThor-/ayn-AYNThor-.conf"

  chmod 755 "${pkgdir}/usr/bin/thorch-rebuild-abl-kernel"
  chmod 755 "${pkgdir}/usr/bin/thorch-check-boot"
  chmod 755 "${pkgdir}/usr/bin/thorch-debug-report"
  chmod 755 "${pkgdir}/usr/bin/thorch-backlight"
  chmod 755 "${pkgdir}/usr/bin/thorch-hw-defaults"
  chmod 755 "${pkgdir}/usr/bin/thorch-hardwarectl"
  rm -f "${pkgdir}/usr/bin/thorch-powerkeyd"
  install -Dm755 "${srcdir}/thorch-inputd" "${pkgdir}/usr/bin/thorch-inputd"
  chmod 755 "${pkgdir}/usr/bin/thorch-rgb"
  chmod 755 "${pkgdir}/usr/bin/thorch-fancontrol"
  chmod 755 "${pkgdir}/usr/bin/thorch-quicksetting-toggle"
  chmod 755 "${pkgdir}/usr/bin/thorch-usb-gadget"
  chmod 755 "${pkgdir}/usr/bin/thorch-usb-network"
  chmod 755 "${pkgdir}/usr/lib/thorch/plasma-mobile-action-drawer-mode"
  chmod 755 "${pkgdir}/usr/lib/initcpio/install/thorch-firmware"
  chmod 755 "${pkgdir}/usr/lib/initcpio/install/thorch-sd-prefer"
  chmod 755 "${pkgdir}/usr/lib/initcpio/hooks/thorch-sd-prefer"
  chmod 755 "${pkgdir}/usr/lib/systemd/system-sleep/thorch-rgb"
  chmod 755 "${pkgdir}/usr/lib/systemd/system-sleep/thorch-powerkey-wake-guard"
  chmod 755 "${pkgdir}/usr/lib/systemd/system-sleep/thorch-usb-role-suspend"
}
