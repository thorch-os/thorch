THORCH_BOOTSTRAP_MARKER_PKGREL=1
THORCH_BOOTSTRAP_MARKER_REQUIREMENT='thorch-boot-bootstrap-ready>=1-1'
THORCH_BOOTSTRAP_BSP_REQUIREMENT='thorch-bsp>=1-27'
