#!/usr/bin/env bash
set -u

phase="${1:-unknown}"
verb="${2:-unknown}"
sysfs_root="${THORCH_SLEEP_POWERSAVE_SYSFS_ROOT:-/sys}"
hw_defaults="${THORCH_SLEEP_POWERSAVE_HW_DEFAULTS:-/usr/bin/thorch-hw-defaults}"
state_file="${THORCH_SLEEP_POWERSAVE_STATE_FILE:-/run/thorch-sleep-powersave.state}"
gpu_devfreq_path="${THORCH_SLEEP_POWERSAVE_GPU_DEVFREQ_PATH:-${THORCH_GPU_DEVFREQ_PATH:-}}"
ufs_devfreq_path="${THORCH_SLEEP_POWERSAVE_UFS_DEVFREQ_PATH:-}"
ufs_host_path="${THORCH_SLEEP_POWERSAVE_UFS_HOST_PATH:-}"

write_sysfs_raw() {
  local path="$1" value="$2"
  [[ -w "${path}" ]] || return 0
  printf '%s' "${value}" >"${path}" 2>/dev/null || true
}

contains_word() {
  local haystack="$1" needle="$2"
  [[ " ${haystack} " == *" ${needle} "* ]]
}

file_has_text() {
  local path="$1"
  [[ -r "${path}" ]] || return 1
  [[ -n "$(tr -d '[:space:]' <"${path}")" ]]
}

cpu_policy_paths() {
  local path

  shopt -s nullglob
  for path in "${sysfs_root}"/devices/system/cpu/cpufreq/policy*; do
    [[ -d "${path}" ]] || continue
    printf '%s\n' "${path}"
  done
  shopt -u nullglob
}

cpu_boost_paths() {
  local -a paths=()
  local path

  if [[ -w "${sysfs_root}/devices/system/cpu/cpufreq/boost" &&
        ! -d "${sysfs_root}/devices/system/cpu/cpufreq/boost" ]]; then
    paths+=("${sysfs_root}/devices/system/cpu/cpufreq/boost")
  fi

  shopt -s nullglob
  for path in "${sysfs_root}"/devices/system/cpu/cpufreq/policy*/boost; do
    [[ -w "${path}" && ! -d "${path}" ]] || continue
    file_has_text "$(dirname "${path}")/scaling_boost_frequencies" || continue
    paths+=("${path}")
  done
  shopt -u nullglob

  printf '%s\n' "${paths[@]}"
}

gpu_devfreq_paths() {
  local path resolved

  if [[ -n "${gpu_devfreq_path}" ]]; then
    if [[ "${gpu_devfreq_path}" == /* ]]; then
      path="${gpu_devfreq_path}"
    else
      path="${sysfs_root}/${gpu_devfreq_path#/}"
    fi
    [[ -d "${path}" ]] && printf '%s\n' "${path}"
    return 0
  fi

  for path in \
    "${sysfs_root}/class/devfreq/3d00000.gpu" \
    "${sysfs_root}/devices/platform/soc@0/3d00000.gpu/devfreq/3d00000.gpu"; do
    [[ -d "${path}" ]] && { printf '%s\n' "${path}"; return 0; }
  done

  shopt -s nullglob
  for path in "${sysfs_root}"/class/devfreq/*; do
    [[ -d "${path}" ]] || continue
    resolved="$(readlink -f "${path}" 2>/dev/null || true)"
    if [[ "${path}" == *gpu* || "${resolved}" == *gpu* ]]; then
      printf '%s\n' "${path}"
    fi
  done
  shopt -u nullglob
}

apply_cpu_gpu_powersave() {
  [[ -x "${hw_defaults}" ]] || return 0
  THORCH_HW_DEFAULTS_SYSFS_ROOT="${sysfs_root}" \
  THORCH_CPU_BOOST=0 \
  THORCH_CPU_GOVERNOR=powersave \
  THORCH_GPU_GOVERNOR=powersave \
    "${hw_defaults}" apply >/dev/null 2>&1 || true
}

ufs_devfreq_paths() {
  local path resolved

  if [[ -n "${ufs_devfreq_path}" ]]; then
    if [[ "${ufs_devfreq_path}" == /* ]]; then
      path="${ufs_devfreq_path}"
    else
      path="${sysfs_root}/${ufs_devfreq_path#/}"
    fi
    [[ -d "${path}" ]] && printf '%s\n' "${path}"
    return 0
  fi

  for path in \
    "${sysfs_root}/class/devfreq/1d84000.ufshc" \
    "${sysfs_root}/devices/platform/soc@0/1d84000.ufshc/devfreq/1d84000.ufshc"; do
    [[ -d "${path}" ]] && printf '%s\n' "${path}"
  done

  shopt -s nullglob
  for path in "${sysfs_root}"/class/devfreq/*; do
    [[ -d "${path}" ]] || continue
    resolved="$(readlink -f "${path}" 2>/dev/null || true)"
    if [[ "${path}" == *ufs* || "${path}" == *ufshc* ||
          "${resolved}" == *ufs* || "${resolved}" == *ufshc* ]]; then
      printf '%s\n' "${path}"
    fi
  done
  shopt -u nullglob
}

ufs_host_paths() {
  local devfreq path resolved

  if [[ -n "${ufs_host_path}" ]]; then
    if [[ "${ufs_host_path}" == /* ]]; then
      path="${ufs_host_path}"
    else
      path="${sysfs_root}/${ufs_host_path#/}"
    fi
    [[ -d "${path}" ]] && printf '%s\n' "${path}"
    return 0
  fi

  for path in \
    "${sysfs_root}/devices/platform/soc@0/1d84000.ufshc" \
    "${sysfs_root}/devices/platform/1d84000.ufshc"; do
    [[ -d "${path}" ]] && printf '%s\n' "${path}"
  done

  while IFS= read -r devfreq; do
    [[ -n "${devfreq}" ]] || continue
    resolved="$(readlink -f "${devfreq}" 2>/dev/null || true)"
    case "${resolved}" in
      */devfreq/*)
        path="${resolved%/devfreq/*}"
        [[ -d "${path}" ]] && printf '%s\n' "${path}"
        ;;
    esac
  done < <(ufs_devfreq_paths)
}

apply_ufs_powersave() {
  local available path ufs

  while IFS= read -r ufs; do
    [[ -n "${ufs}" ]] || continue
    path="${ufs}/governor"
    [[ -w "${path}" ]] || continue
    if [[ -r "${ufs}/available_governors" ]]; then
      available="$(<"${ufs}/available_governors")"
      contains_word "${available}" powersave || continue
    fi
    write_sysfs_raw "${path}" powersave
  done < <(ufs_devfreq_paths | sort -u)
}

disable_ufs_clk_features() {
  local host

  while IFS= read -r host; do
    [[ -n "${host}" ]] || continue
    write_sysfs_raw "${host}/clkscale_enable" 0
    write_sysfs_raw "${host}/clkgate_enable" 0
  done < <(ufs_host_paths | sort -u)
}

record_state() {
  local file="$1" path="$2" value
  [[ -r "${path}" && ! -d "${path}" ]] || return 0
  value="$(cat "${path}" 2>/dev/null || true)"
  printf '%s\t%s\n' "${path}" "${value}" >>"${file}" 2>/dev/null || true
}

save_state() {
  local path policy gpu ufs host tmp state_dir

  state_dir="$(dirname "${state_file}")"
  mkdir -p "${state_dir}" 2>/dev/null || return 0
  tmp="$(mktemp "${state_file}.XXXXXX" 2>/dev/null)" || return 0

  while IFS= read -r policy; do
    [[ -n "${policy}" ]] || continue
    record_state "${tmp}" "${policy}/scaling_governor"
  done < <(cpu_policy_paths | sort -u)

  while IFS= read -r path; do
    [[ -n "${path}" ]] || continue
    record_state "${tmp}" "${path}"
  done < <(cpu_boost_paths | sort -u)

  while IFS= read -r gpu; do
    [[ -n "${gpu}" ]] || continue
    record_state "${tmp}" "${gpu}/governor"
  done < <(gpu_devfreq_paths | sort -u)

  while IFS= read -r ufs; do
    [[ -n "${ufs}" ]] || continue
    record_state "${tmp}" "${ufs}/governor"
  done < <(ufs_devfreq_paths | sort -u)

  while IFS= read -r host; do
    [[ -n "${host}" ]] || continue
    record_state "${tmp}" "${host}/clkscale_enable"
    record_state "${tmp}" "${host}/clkgate_enable"
  done < <(ufs_host_paths | sort -u)

  if [[ -s "${tmp}" ]]; then
    chmod 600 "${tmp}" 2>/dev/null || true
    mv -f "${tmp}" "${state_file}" 2>/dev/null || rm -f "${tmp}"
  else
    rm -f "${tmp}"
  fi
}

restore_state() {
  local path value
  [[ -r "${state_file}" ]] || return 0

  while IFS=$'\t' read -r path value; do
    [[ -n "${path}" ]] || continue
    write_sysfs_raw "${path}" "${value}"
  done <"${state_file}"

  rm -f "${state_file}"
}

case "${phase}" in
  pre)
    [[ "${verb}" == "suspend" ]] || exit 0
    save_state
    apply_cpu_gpu_powersave
    apply_ufs_powersave
    disable_ufs_clk_features
    ;;
  post)
    [[ "${verb}" == "suspend" ]] || exit 0
    restore_state
    ;;
esac

exit 0
