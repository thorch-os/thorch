#!/usr/bin/env bash
set -euo pipefail

sysfs_root="${THORCH_HW_DEFAULTS_SYSFS_ROOT:-/sys}"
cpu_boost_setting="${THORCH_CPU_BOOST:-1}"
cpu_governor_setting="${THORCH_CPU_GOVERNOR:-performance}"
gpu_governor_setting="${THORCH_GPU_GOVERNOR:-performance}"
gpu_devfreq_path="${THORCH_GPU_DEVFREQ_PATH:-}"
disable_cpu0_idle_state1_setting="${THORCH_DISABLE_CPU0_IDLE_STATE1:-1}"

boolean_to_sysfs() {
  case "$1" in
    1|true|TRUE|yes|YES|on|ON|enabled|ENABLED)
      printf '1'
      ;;
    *)
      printf '0'
      ;;
  esac
}

file_has_text() {
  local path="$1"
  [[ -r "${path}" ]] || return 1
  [[ -n "$(tr -d '[:space:]' < "${path}")" ]]
}

write_sysfs() {
  local path="$1" value="$2"
  if ! { printf '%s\n' "${value}" > "${path}"; } 2>/dev/null; then
    printf 'warning: could not write %s to %s\n' "${value}" "${path}" >&2
    return 1
  fi
}

write_sysfs_raw() {
  local path="$1" value="$2"
  if ! { printf '%s' "${value}" > "${path}"; } 2>/dev/null; then
    printf 'warning: could not write %s to %s\n' "${value}" "${path}" >&2
    return 1
  fi
}

cpu_policy_paths() {
  local path

  shopt -s nullglob
  for path in "${sysfs_root}"/devices/system/cpu/cpufreq/policy*; do
    [[ -d "${path}" ]] || continue
    printf '%s\n' "${path}"
  done
  shopt -u nullglob
}

cpu_boost_paths() {
  local -a paths=()
  local path

  if [[ -w "${sysfs_root}/devices/system/cpu/cpufreq/boost" && ! -d "${sysfs_root}/devices/system/cpu/cpufreq/boost" ]]; then
    paths+=("${sysfs_root}/devices/system/cpu/cpufreq/boost")
  fi

  shopt -s nullglob
  for path in "${sysfs_root}"/devices/system/cpu/cpufreq/policy*/boost; do
    [[ -w "${path}" && ! -d "${path}" ]] || continue
    file_has_text "$(dirname "${path}")/scaling_boost_frequencies" || continue
    paths+=("${path}")
  done
  shopt -u nullglob

  printf '%s\n' "${paths[@]}"
}

gpu_devfreq_paths() {
  local path resolved

  if [[ -n "${gpu_devfreq_path}" ]]; then
    if [[ "${gpu_devfreq_path}" == /* ]]; then
      path="${gpu_devfreq_path}"
    else
      path="${sysfs_root}/${gpu_devfreq_path#/}"
    fi
    [[ -d "${path}" ]] && printf '%s\n' "${path}"
    return 0
  fi

  for path in \
    "${sysfs_root}/class/devfreq/3d00000.gpu" \
    "${sysfs_root}/devices/platform/soc@0/3d00000.gpu/devfreq/3d00000.gpu"; do
    [[ -d "${path}" ]] && { printf '%s\n' "${path}"; return 0; }
  done

  shopt -s nullglob
  for path in "${sysfs_root}"/class/devfreq/*; do
    [[ -d "${path}" ]] || continue
    resolved="$(readlink -f "${path}" 2>/dev/null || true)"
    if [[ "${path}" == *gpu* || "${resolved}" == *gpu* ]]; then
      printf '%s\n' "${path}"
    fi
  done
  shopt -u nullglob
}

policy_max_frequency() {
  local policy="$1"
  local file token max=0

  for file in cpuinfo_max_freq scaling_boost_frequencies scaling_available_frequencies; do
    [[ -r "${policy}/${file}" ]] || continue
    while IFS= read -r token; do
      [[ "${token}" =~ ^[0-9]+$ ]] || continue
      (( token > max )) && max="${token}"
    done < <(tr '[:space:]' '\n' < "${policy}/${file}")
  done

  (( max > 0 )) && printf '%s\n' "${max}"
}

apply_cpu_boost() {
  local value path
  value="$(boolean_to_sysfs "${cpu_boost_setting}")"
  while IFS= read -r path; do
    [[ -n "${path}" ]] || continue
    write_sysfs "${path}" "${value}" || true
  done < <(cpu_boost_paths)
}

apply_cpu_max_freq() {
  local policy max_freq max_path

  [[ "$(boolean_to_sysfs "${cpu_boost_setting}")" == "1" ]] || return 0

  while IFS= read -r policy; do
    [[ -n "${policy}" ]] || continue
    max_path="${policy}/scaling_max_freq"
    [[ -w "${max_path}" ]] || continue
    max_freq="$(policy_max_frequency "${policy}")"
    [[ -n "${max_freq}" ]] || continue
    write_sysfs "${max_path}" "${max_freq}" || true
  done < <(cpu_policy_paths)
}

apply_cpu_governor() {
  local available path policy value
  value="${cpu_governor_setting}"
  [[ -n "${value}" && "${value}" != "auto" ]] || return 0

  while IFS= read -r policy; do
    [[ -n "${policy}" ]] || continue
    path="${policy}/scaling_governor"
    [[ -w "${path}" ]] || continue
    if [[ -r "${policy}/scaling_available_governors" ]]; then
      available="$(<"${policy}/scaling_available_governors")"
      [[ " ${available} " == *" ${value} "* ]] || continue
    fi
    write_sysfs_raw "${path}" "${value}" || true
  done < <(cpu_policy_paths)
}

apply_gpu_governor() {
  local available gpu path value
  value="${gpu_governor_setting}"
  [[ -n "${value}" && "${value}" != "auto" ]] || return 0

  while IFS= read -r gpu; do
    [[ -n "${gpu}" ]] || continue
    path="${gpu}/governor"
    [[ -w "${path}" ]] || continue
    if [[ -r "${gpu}/available_governors" ]]; then
      available="$(<"${gpu}/available_governors")"
      [[ " ${available} " == *" ${value} "* ]] || continue
    fi
    write_sysfs_raw "${path}" "${value}" || true
  done < <(gpu_devfreq_paths)
}

cpu0_idle_state1_disable_path() {
  printf '%s\n' "${sysfs_root}/devices/system/cpu/cpu0/cpuidle/state1/disable"
}

apply_cpu0_idle_workaround() {
  local path value
  path="$(cpu0_idle_state1_disable_path)"
  [[ -w "${path}" && ! -d "${path}" ]] || return 0
  value="$(boolean_to_sysfs "${disable_cpu0_idle_state1_setting}")"
  write_sysfs "${path}" "${value}" || true
}

status_cpu0_idle_workaround() {
  local path
  path="$(cpu0_idle_state1_disable_path)"
  [[ -r "${path}" ]] || return 0
  printf '%s=%s\n' "${path}" "$(cat "${path}")"
}

status_governors() {
  local gpu policy
  while IFS= read -r policy; do
    [[ -n "${policy}" && -r "${policy}/scaling_governor" ]] || continue
    printf '%s/scaling_governor=%s\n' "${policy}" "$(cat "${policy}/scaling_governor")"
  done < <(cpu_policy_paths)
  while IFS= read -r gpu; do
    [[ -n "${gpu}" && -r "${gpu}/governor" ]] || continue
    printf '%s/governor=%s\n' "${gpu}" "$(cat "${gpu}/governor")"
  done < <(gpu_devfreq_paths)
}

status_defaults() {
  local path
  while IFS= read -r path; do
    [[ -n "${path}" ]] || continue
    printf '%s=%s\n' "${path}" "$(cat "${path}")"
  done < <(cpu_boost_paths)
}

case "${1:-apply}" in
  apply)
    apply_cpu0_idle_workaround
    apply_cpu_boost
    apply_cpu_max_freq
    apply_cpu_governor
    apply_gpu_governor
    ;;
  status)
    status_defaults
    status_cpu0_idle_workaround
    status_governors
    ;;
  *)
    printf 'usage: %s [apply|status]\n' "$0" >&2
    exit 2
    ;;
esac
