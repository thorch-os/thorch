#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: thorch-rebuild-abl-kernel [options]

Options:
  --boot-dir DIR          boot filesystem mount (default: /boot)
  --root-uuid UUID        root filesystem UUID; inferred from /proc/cmdline
  --rootfstype TYPE       ext4 or btrfs (default: ext4)
  --source-kernel PATH    imported ROCKNIX Android boot template
  --initramfs PATH        initramfs to embed (default: BOOT_DIR/initramfs-linux-thorch.img)
  --output PATH           destination (default: BOOT_DIR/KERNEL)
  --no-retain-previous    do not preserve an existing live KERNEL

Rebuilds the Android-style /KERNEL boot image expected by the Thor ABL Linux
path. The candidate is built and validated on the destination filesystem,
flushed, and renamed into place. When replacing BOOT_DIR/KERNEL, the previous
payload is durably retained as BOOT_DIR/KERNEL.previous. This does not flash ABL.
EOF
}

require_value() {
  local opt="$1" value="${2:-}"
  [[ -n "${value}" ]] || {
    usage
    echo "${opt} requires a value" >&2
    exit 2
  }
}

fail() {
  echo "error: $*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || fail "missing command: $1"
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
boot_tool="${THORCH_BOOT_IMAGE_TOOL:-${script_dir}/../lib/thorch/boot_image.py}"
boot_dir=/boot
root_uuid=""
rootfstype=ext4
source_kernel=""
initrd_image=""
output=""
retain_previous=1

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --boot-dir)
      require_value "$1" "${2:-}"
      boot_dir="$2"
      shift 2
      ;;
    --root-uuid)
      require_value "$1" "${2:-}"
      root_uuid="$2"
      shift 2
      ;;
    --rootfstype)
      require_value "$1" "${2:-}"
      rootfstype="$2"
      shift 2
      ;;
    --source-kernel)
      require_value "$1" "${2:-}"
      source_kernel="$2"
      shift 2
      ;;
    --initramfs)
      require_value "$1" "${2:-}"
      initrd_image="$2"
      shift 2
      ;;
    --output)
      require_value "$1" "${2:-}"
      output="$2"
      shift 2
      ;;
    --no-retain-previous)
      retain_previous=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

need mkbootimg
need python3
[[ -f "${boot_tool}" ]] || fail "missing canonical boot-image tool: ${boot_tool}"

case "${rootfstype}" in
  ext4|btrfs) ;;
  *) fail "unsupported rootfstype: ${rootfstype}; use ext4 or btrfs" ;;
esac

if [[ -z "${root_uuid}" ]]; then
  cmdline="$(cat /proc/cmdline 2>/dev/null || true)"
  if [[ "${cmdline}" =~ root=UUID=([^[:space:]]+) ]]; then
    root_uuid="${BASH_REMATCH[1]}"
  else
    fail "unable to find root UUID; pass --root-uuid"
  fi
fi

boot_dir="${boot_dir%/}"
[[ -n "${boot_dir}" ]] || boot_dir=/
initrd_image="${initrd_image:-${boot_dir}/initramfs-linux-thorch.img}"
output="${output:-${boot_dir}/KERNEL}"
[[ -f "${initrd_image}" ]] || fail "missing initramfs: ${initrd_image}"
install -d "$(dirname "${output}")"

if [[ -z "${source_kernel}" ]]; then
  if [[ "${boot_dir}" == "/boot" ]]; then
    source_kernel=/usr/share/thorch/rocknix/KERNEL
  elif [[ "${boot_dir}" == */boot ]]; then
    source_kernel="${boot_dir%/boot}/usr/share/thorch/rocknix/KERNEL"
  else
    source_kernel="${boot_dir}/KERNEL.rocknix"
  fi
fi
[[ -f "${source_kernel}" ]] || fail "missing imported ROCKNIX boot image: ${source_kernel}"

tmpdir="$(mktemp -d)"
stage="$(mktemp "$(dirname "${output}")/.KERNEL.new.XXXXXX")"
rm -f "${stage}"
cleanup() {
  rm -rf "${tmpdir}"
  rm -f "${stage}"
}
trap cleanup EXIT

mkdir -p "${tmpdir}/py/gki"
touch "${tmpdir}/py/gki/__init__.py"
cat > "${tmpdir}/py/gki/generate_gki_certificate.py" <<'PY'
def generate_gki_certificate(*args, **kwargs):
    return None
PY

python3 "${boot_tool}" prepare-repack "${source_kernel}" "${tmpdir}"

# shellcheck disable=SC1091
. "${tmpdir}/bootimg.env"
cmdline="panic=30 audit=0 quiet rw rootwait rootdelay=15 allow_mismatched_32bit_el0 fw_devlink.strict=1 pcie_ports=compat irqaffinity=0-2 cgroup.memory=nokmem,nosocket nosoftlockup usbcore.interrupt_interval_override=045e:028e:2 mem_sleep_default=deep ufshcd_core.uic_cmd_timeout=3000 console=tty0 console=ttyMSM0,115200n8 fbcon=rotate:1 root=UUID=${root_uuid} rootfstype=${rootfstype}"
mkbootimg_args=(
  --kernel "${tmpdir}/kernel"
  --ramdisk "${initrd_image}"
  --base 0x0
  --kernel_offset "${KERNEL_ADDR}"
  --ramdisk_offset "${RAMDISK_ADDR}"
  --second_offset "${SECOND_ADDR}"
  --tags_offset "${TAGS_ADDR}"
  --pagesize "${PAGE_SIZE}"
  --cmdline "${cmdline}"
)
if [[ "${HAS_SECOND}" == "1" ]]; then
  mkbootimg_args+=(--second "${tmpdir}/second")
fi
PYTHONPATH="${tmpdir}/py${PYTHONPATH:+:${PYTHONPATH}}" \
  mkbootimg "${mkbootimg_args[@]}" -o "${stage}"

python3 "${boot_tool}" validate "${stage}" \
  --expect-root-uuid "${root_uuid}" \
  --require-cmdline fbcon=rotate:1 \
  --require-cmdline allow_mismatched_32bit_el0 \
  --require-symbols \
  --require-thor \
  --forbid-aim300 \
  --expect-ramdisk "${initrd_image}"

python3 - "${stage}" "${output}" "${boot_dir}/KERNEL" "${boot_dir}/KERNEL.previous" "${retain_previous}" <<'PY'
import os
import pathlib
import shutil
import sys
import tempfile

stage = pathlib.Path(sys.argv[1])
output = pathlib.Path(sys.argv[2])
live = pathlib.Path(sys.argv[3])
previous = pathlib.Path(sys.argv[4])
retain_previous = sys.argv[5] == "1"

with stage.open("rb") as candidate:
    os.fsync(candidate.fileno())

if retain_previous and output == live and live.is_file():
    previous.parent.mkdir(parents=True, exist_ok=True)
    fd, temporary_name = tempfile.mkstemp(prefix=".KERNEL.previous.", dir=previous.parent)
    temporary = pathlib.Path(temporary_name)
    try:
        with os.fdopen(fd, "wb") as destination, live.open("rb") as source:
            shutil.copyfileobj(source, destination)
            destination.flush()
            os.fsync(destination.fileno())
        os.replace(temporary, previous)
    finally:
        temporary.unlink(missing_ok=True)

os.replace(stage, output)
directory_fd = os.open(output.parent, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0))
try:
    os.fsync(directory_fd)
finally:
    os.close(directory_fd)
PY

echo "repacked ${output} from ${source_kernel} for root UUID ${root_uuid}"
