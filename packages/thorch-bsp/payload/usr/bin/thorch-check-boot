#!/usr/bin/env bash
set -euo pipefail

boot_dir=/boot
require_value() {
  local opt="$1" value="${2:-}"
  [[ -n "${value}" ]] || {
    echo "usage: thorch-check-boot [--boot-dir /boot]" >&2
    echo "${opt} requires a value" >&2
    exit 2
  }
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --boot-dir)
      require_value "$1" "${2:-}"
      boot_dir="$2"
      shift 2
      ;;
    -h|--help)
      echo "usage: thorch-check-boot [--boot-dir /boot]" >&2
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

failures=0
check_file() {
  local label="$1" path="$2"
  if [[ -f "${path}" ]]; then
    printf 'ok: %s\n' "${label}"
  else
    printf 'FAIL: %s (%s)\n' "${label}" "${path}" >&2
    failures=$((failures + 1))
  fi
}

check_file "Thorch initramfs" "${boot_dir}/initramfs-linux-thorch.img"
check_file "Android boot image KERNEL" "${boot_dir}/KERNEL"

if [[ -f "${boot_dir}/KERNEL" ]] && command -v file >/dev/null 2>&1; then
  file -b "${boot_dir}/KERNEL" | grep -q '^Android bootimg' || failures=$((failures + 1))
fi

if [[ -f "${boot_dir}/KERNEL" ]]; then
  python3 - "${boot_dir}/KERNEL" <<'PY' || failures=$((failures + 1))
import pathlib
import struct
import sys

kernel = pathlib.Path(sys.argv[1]).read_bytes()
missing = [
    marker.decode("ascii")
    for marker in (b"root=UUID=", b"fbcon=rotate:1")
    if marker not in kernel
]

magic = b"\xd0\r\xfe\xed"
pos = 0
has_thor_dtb = False
while True:
    at = kernel.find(magic, pos)
    if at < 0:
        break
    if len(kernel) < at + 8:
        break
    size = struct.unpack_from(">I", kernel, at + 4)[0]
    if size < 8 or len(kernel) < at + size:
        pos = at + 4
        continue
    dtb = kernel[at:at + size]
    if b"AYN Thor\x00" in dtb and b"ayn,thor\x00" in dtb:
        has_thor_dtb = True
        break
    pos = at + size

if not has_thor_dtb:
    missing.append("embedded Thor DTB")

if missing:
    print("KERNEL missing: " + ", ".join(missing), file=sys.stderr)
    sys.exit(1)
PY
fi

if [[ "${failures}" -ne 0 ]]; then
  echo "Thorch boot validation failed: ${failures} issue(s)" >&2
  exit 1
fi

echo "Thorch boot validation passed"
