#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: thorch-check-boot [--boot-dir /boot] [--kernel PATH] [--root-uuid UUID]" >&2
}

require_value() {
  local opt="$1" value="${2:-}"
  [[ -n "${value}" ]] || {
    usage
    echo "${opt} requires a value" >&2
    exit 2
  }
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
boot_tool="${THORCH_BOOT_IMAGE_TOOL:-${script_dir}/../lib/thorch/boot_image.py}"
boot_dir=/boot
kernel_path=""
root_uuid="${THORCH_BOOT_ROOT_UUID:-}"

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --boot-dir)
      require_value "$1" "${2:-}"
      boot_dir="$2"
      shift 2
      ;;
    --kernel)
      require_value "$1" "${2:-}"
      kernel_path="$2"
      shift 2
      ;;
    --root-uuid)
      require_value "$1" "${2:-}"
      root_uuid="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

boot_dir="${boot_dir%/}"
[[ -n "${boot_dir}" ]] || boot_dir=/
kernel_path="${kernel_path:-${boot_dir}/KERNEL}"
initramfs_path="${boot_dir}/initramfs-linux-thorch.img"
failures=0

if [[ -z "${root_uuid}" && "${boot_dir}" == "/boot" ]] && command -v findmnt >/dev/null 2>&1; then
  root_uuid="$(findmnt -nro UUID / 2>/dev/null || true)"
fi
if [[ -z "${root_uuid}" && "${boot_dir}" == "/boot" ]]; then
  cmdline="$(cat /proc/cmdline 2>/dev/null || true)"
  if [[ "${cmdline}" =~ (^|[[:space:]])root=UUID=([^[:space:]]+)($|[[:space:]]) ]]; then
    root_uuid="${BASH_REMATCH[2]}"
  fi
fi
if [[ -z "${root_uuid}" ]]; then
  printf 'FAIL: expected root UUID (pass --root-uuid for an offline boot directory)\n' >&2
  failures=$((failures + 1))
fi

check_file() {
  local label="$1" path="$2"
  if [[ -s "${path}" ]]; then
    printf 'ok: %s\n' "${label}"
  else
    printf 'FAIL: %s (%s)\n' "${label}" "${path}" >&2
    failures=$((failures + 1))
  fi
}

check_file "Thorch initramfs" "${initramfs_path}"
check_file "Android boot image KERNEL" "${kernel_path}"
check_file "canonical boot-image validator" "${boot_tool}"

if [[ -f "${kernel_path}" && -f "${boot_tool}" && -n "${root_uuid}" ]]; then
  if python3 "${boot_tool}" validate "${kernel_path}" \
    --expect-root-uuid "${root_uuid}" \
    --require-cmdline fbcon=rotate:1 \
    --require-cmdline allow_mismatched_32bit_el0 \
    --require-symbols \
    --require-thor \
    --forbid-aim300 \
    --expect-ramdisk "${initramfs_path}"; then
    printf 'ok: Android boot image invariants\n'
  else
    failures=$((failures + 1))
  fi
fi

if [[ "${failures}" -ne 0 ]]; then
  echo "Thorch boot validation failed: ${failures} issue(s)" >&2
  exit 1
fi

echo "Thorch boot validation passed"
