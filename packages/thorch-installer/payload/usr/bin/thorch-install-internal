#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: thorch-install-internal [--boot-device /dev/... --root-device /dev/...]
       thorch-install-internal --create-from-userdata [--userdata-keep-gib N|auto] [--yes]

Installs the currently running Thorch SD system to internal Thor Linux storage.
This formats the selected boot and root partitions, but never flashes ABL.

Without device arguments, Thorch auto-detects an existing internal Linux install
target using ROCKNIX/Thorch labels. It will not create partitions, shrink
Android userdata, or wipe Android userdata unless --create-from-userdata is
passed explicitly. When --create-from-userdata is passed, an existing target is
still preferred; Android userdata is only changed if no existing target is found.

Required safety confirmation: type INSTALL THORCH when prompted.
EOF
}

require_value() {
  local opt="$1" value="${2:-}"
  [[ -n "${value}" ]] || {
    usage
    echo "${opt} requires a value" >&2
    exit 2
  }
}

boot_device=""
root_device=""
target=/mnt/thorch-internal
create_from_userdata=0
userdata_keep_gib=""
assume_yes=0
root_fstype=""
root_mount_options=""
root_fstab_pass=""

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --boot-device)
      require_value "$1" "${2:-}"
      boot_device="$2"
      shift 2
      ;;
    --root-device)
      require_value "$1" "${2:-}"
      root_device="$2"
      shift 2
      ;;
    --target)
      require_value "$1" "${2:-}"
      target="$2"
      shift 2
      ;;
    --create-from-userdata)
      create_from_userdata=1
      shift
      ;;
    --userdata-keep-gib)
      require_value "$1" "${2:-}"
      userdata_keep_gib="$2"
      shift 2
      ;;
    --yes)
      assume_yes=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

fail() {
  echo "error: $*" >&2
  exit 1
}

confirm_or_fail() {
  local expected="$1" prompt="$2" confirmation
  if [[ "${assume_yes}" -eq 1 ]]; then
    echo "${prompt}${expected}"
    return 0
  fi

  printf '%s' "${prompt}"
  read -r confirmation
  [[ "${confirmation}" == "${expected}" ]] || fail "confirmation did not match; aborting"
}

need() {
  command -v "$1" >/dev/null 2>&1 || fail "missing command: $1"
}

require_root() {
  [[ "${EUID}" -eq 0 ]] || fail "run as root"
}

base_block() {
  local dev="$1" pk base
  pk="$(lsblk -no PKNAME "${dev}" 2>/dev/null | head -n1 || true)"
  if [[ -n "${pk}" ]]; then
    printf '%s\n' "${pk}"
    return
  fi
  base="$(basename "${dev}")"
  base="${base%%p[0-9]*}"
  base="${base%%[0-9]*}"
  printf '%s\n' "${base}"
}

is_removable_root() {
  local src base removable root_label boot_src boot_label
  src="$(findmnt -n -o SOURCE /)"
  [[ "${src}" == /dev/* ]] || return 1
  base="$(base_block "${src}")"
  removable="/sys/class/block/${base}/removable"
  [[ -f "${removable}" ]] && [[ "$(cat "${removable}")" == "1" ]] && return 0

  # Thor reports the external SD slot as non-removable. Accept the Thorch SD
  # image shape as the second safety signal: root on mmcblk*, root label
  # THORCH_ROOT, and /boot label ROCKNIX on the same mmc block device.
  [[ "${base}" == mmcblk* ]] || return 1
  root_label="$(blkid -s LABEL -o value "${src}" 2>/dev/null || true)"
  [[ "${root_label}" == "THORCH_ROOT" ]] || return 1
  boot_src="$(findmnt -n -o SOURCE /boot 2>/dev/null || true)"
  [[ "${boot_src}" == /dev/* ]] || return 1
  [[ "$(base_block "${boot_src}")" == "${base}" ]] || return 1
  boot_label="$(blkid -s LABEL -o value "${boot_src}" 2>/dev/null || true)"
  [[ "${boot_label}" == "ROCKNIX" ]]
}

reject_android_partition() {
  local dev="$1" text
  text="$(lsblk -no NAME,LABEL,PARTLABEL "${dev}" 2>/dev/null | tr '[:upper:]' '[:lower:]')"
  if grep -Eq '(^|[[:space:]])(abl|boot_[ab]|vendor|system|super|metadata|userdata|dtbo|vbmeta|persist|modem|bluetooth|dsp|xbl|tz|hyp|keymaster|recovery)([[:space:]]|$)' <<<"${text}"; then
    fail "${dev} looks like an Android partition: ${text}"
  fi
}

current_root_base() {
  local src
  src="$(findmnt -n -o SOURCE /)"
  [[ "${src}" == /dev/* ]] || return 1
  base_block "${src}"
}

partition_label() {
  blkid -s LABEL -o value "$1" 2>/dev/null || true
}

partition_partlabel() {
  lsblk -no PARTLABEL "$1" 2>/dev/null | head -n1 || true
}

partition_fstype() {
  lsblk -no FSTYPE "$1" 2>/dev/null | awk 'NF {print $1; exit}' || true
}

supported_root_fstype() {
  case "$1" in
    ext4|btrfs)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

current_root_fstype() {
  findmnt -no FSTYPE / 2>/dev/null | awk 'NF {print $1; exit}' || true
}

configure_root_filesystem() {
  local requested current

  current="$(current_root_fstype)"
  requested="${THORCH_ROOT_FSTYPE:-${current}}"
  requested="${requested,,}"
  if ! supported_root_fstype "${requested}"; then
    if [[ -n "${THORCH_ROOT_FSTYPE:-}" ]]; then
      fail "unsupported THORCH_ROOT_FSTYPE: ${THORCH_ROOT_FSTYPE}; use ext4 or btrfs"
    fi
    requested=ext4
  fi

  case "${requested}" in
    ext4)
      need mkfs.ext4
      root_mount_options="rw,relatime"
      root_fstab_pass=1
      ;;
    btrfs)
      need mkfs.btrfs
      need btrfs
      root_mount_options="${THORCH_BTRFS_MOUNT_OPTIONS:-rw,relatime,compress=zstd:1}"
      root_fstab_pass=0
      ;;
  esac

  [[ "${root_mount_options}" != *[[:space:]]* ]] || fail "root mount options must not contain whitespace: ${root_mount_options}"
  root_fstype="${requested}"
}

format_root_device() {
  case "${root_fstype}" in
    ext4)
      mkfs.ext4 -F -L THORCH_ROOT "${root_device}"
      ;;
    btrfs)
      mkfs.btrfs -f -L THORCH_ROOT "${root_device}"
      ;;
  esac
}

partition_start() {
  local dev="$1" real sys start
  real="$(readlink -f "${dev}" 2>/dev/null || printf '%s\n' "${dev}")"
  sys="/sys/class/block/$(basename "${real}")/start"
  if [[ -r "${sys}" ]]; then
    read -r start < "${sys}"
  else
    start="$(lsblk -no START "${dev}" 2>/dev/null | awk 'NF {print $1; exit}')"
  fi
  [[ "${start:-}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$(( start * 512 ))"
}

partition_end() {
  local start size
  start="$(partition_start "$1")" || return 1
  size="$(blockdev --getsize64 "$1")" || return 1
  printf '%s\n' "$(( start + size ))"
}

partition_node() {
  local disk="$1" num="$2"
  if [[ "${disk}" =~ (nvme|mmcblk|loop)[0-9] ]]; then
    printf '%sp%s\n' "${disk}" "${num}"
  else
    printf '%s%s\n' "${disk}" "${num}"
  fi
}

partprobe_wait() {
  local disk="$1"
  partprobe "${disk}" 2>/dev/null || true
  udevadm settle 2>/dev/null || true
}

internal_userdata_disk() {
  local current_base name type disk count=0 found=""
  current_base="$(current_root_base)"

  while read -r name type; do
    [[ "${type}" == "part" ]] || continue
    [[ "$(partition_partlabel "${name}")" == "userdata" ]] || continue
    disk="/dev/$(base_block "${name}")"
    [[ "$(basename "${disk}")" != "${current_base}" ]] || continue
    found="${disk}"
    count=$((count + 1))
  done < <(lsblk -nrpo NAME,TYPE)

  [[ "${count}" -eq 1 ]] || return 1
  printf '%s\n' "${found}"
}

partition_numbers() {
  parted -m -s "$1" unit B print |
    awk -F: '$1 ~ /^[0-9]+$/ {print $1}' |
    sort -n
}

new_partition_number_since() {
  local disk="$1" before="$2" num found="" count=0
  while IFS= read -r num; do
    [[ -n "${num}" ]] || continue
    if ! grep -qxF "${num}" <<<"${before}"; then
      found="${num}"
      count=$((count + 1))
    fi
  done < <(partition_numbers "${disk}")

  [[ "${count}" -eq 1 ]] || fail "could not identify the new partition number on ${disk}"
  printf '%s\n' "${found}"
}

userdata_bounds() {
  local disk="$1" ud_line ud_start_b ud_end_b ud_start ud_end
  local -a ud_matches=()
  mapfile -t ud_matches < <(parted -m -s "${disk}" unit B print | grep ':userdata:')
  [[ "${#ud_matches[@]}" -eq 1 ]] || fail "could not uniquely find Android userdata on ${disk}"
  ud_line="${ud_matches[0]}"
  IFS=':' read -r ud_num ud_start_b ud_end_b _ <<< "${ud_line}"
  ud_start="${ud_start_b%B}"
  ud_end="${ud_end_b%B}"
  ud_node="$(partition_node "${disk}" "${ud_num}")"
  ud_start_mib=$(( (ud_start + 1048575) / 1048576 ))
  ud_end_mib=$(( ud_end / 1048576 ))
}

disk_end_mib() {
  local disk="$1" size_b
  size_b="$(blockdev --getsize64 "${disk}")"
  printf '%s\n' "$(( size_b / 1048576 ))"
}

is_partition_after_userdata() {
  local dev="$1" ud_end_bytes="$2" start
  start="$(partition_start "${dev}")" || return 1
  (( start >= ud_end_bytes ))
}

delete_partitions_after_userdata() {
  local disk="$1" ud_end_bytes="$2" name num
  while read -r name; do
    [[ -n "${name}" ]] || continue
    is_partition_after_userdata "${name}" "${ud_end_bytes}" || continue
    require_unmounted "${name}"
    num="${name##*[!0-9]}"
    [[ -n "${num}" ]] || fail "could not parse partition number from ${name}"
    echo "removing stale post-userdata partition ${name}"
    parted -s "${disk}" rm "${num}"
  done < <(lsblk -nrpo NAME,TYPE "${disk}" | awk '$2 == "part" {print $1}' | sort -Vr)
  partprobe_wait "${disk}"
}

create_target_in_free_space_after_userdata() {
  local disk="$1" boot_start_mib="$2" disk_mib="$3" before_nums boot_num root_num boot_end_mib
  boot_end_mib=$(( boot_start_mib + 2048 ))
  (( disk_mib - boot_end_mib >= 8192 )) || fail "not enough free space after Android userdata for Thorch"

  echo ":: thorch-install phase=create-boot"
  before_nums="$(partition_numbers "${disk}")"
  parted -a optimal -s "${disk}" mkpart primary fat32 "${boot_start_mib}MiB" "${boot_end_mib}MiB"
  boot_num="$(new_partition_number_since "${disk}" "${before_nums}")"
  parted -s "${disk}" name "${boot_num}" ROCKNIX
  parted -s "${disk}" set "${boot_num}" msftdata on || true
  parted -s "${disk}" set "${boot_num}" boot on || true

  echo ":: thorch-install phase=create-root"
  before_nums="$(partition_numbers "${disk}")"
  parted -a optimal -s "${disk}" mkpart primary "${root_fstype}" "${boot_end_mib}MiB" 100%
  root_num="$(new_partition_number_since "${disk}" "${before_nums}")"
  parted -s "${disk}" name "${root_num}" STORAGE
  partprobe_wait "${disk}"

  boot_device="$(partition_node "${disk}" "${boot_num}")"
  root_device="$(partition_node "${disk}" "${root_num}")"
  [[ -b "${boot_device}" && -b "${root_device}" ]] || fail "new Thorch partitions did not appear"
}

create_target_by_reusing_resized_userdata() {
  local disk="$1" ud_num ud_node ud_start_mib ud_end_mib disk_mib free_mib
  userdata_bounds "${disk}"
  require_unmounted "${ud_node}"
  disk_mib="$(disk_end_mib "${disk}")"
  free_mib=$(( disk_mib - ud_end_mib ))
  (( free_mib >= 10240 )) || return 1

  cat <<EOF
No complete internal Thorch/ROCKNIX target was found, but Android userdata is
already smaller than the disk and leaves ${free_mib} MiB for internal Linux.

Thorch will reuse that post-userdata area and will not shrink Android userdata.
Any stale partitions after userdata will be recreated.

Thorch will create an internal Linux target without changing Android userdata:
  ROCKNIX boot: 2 GiB after userdata
  Thorch root:  remaining free space
EOF

  confirm_or_fail "CREATE THORCH" "Type CREATE THORCH to continue: "
  delete_partitions_after_userdata "${disk}" "$(( ud_end_mib * 1048576 ))"
  create_target_in_free_space_after_userdata "${disk}" "${ud_end_mib}" "${disk_mib}"
}

create_target_by_shrinking_userdata() {
  local disk="$1" confirm ud_num ud_node ud_start_mib ud_end_mib
  local orig_gib min_gib reserve_gib max_gib keep_gib new_ud_end_mib disk_mib before_nums

  userdata_bounds "${disk}"
  require_unmounted "${ud_node}"
  disk_mib="$(disk_end_mib "${disk}")"

  if (( disk_mib - ud_end_mib >= 10240 )); then
    create_target_by_reusing_resized_userdata "${disk}"
    return 0
  fi

  cat <<EOF
No existing internal Thorch/ROCKNIX Linux install target was found.

Thorch can create one by shrinking Android userdata on:
  ${disk}

This matches the ROCKNIX install-to-internal flow:
  - Android userdata is deleted and recreated smaller.
  - Android userdata contents are wiped.
  - A 2 GiB ROCKNIX boot partition is created.
  - The remaining space becomes Thorch's internal Linux root partition.
  - ABL and Android bootloader partitions are not flashed.
EOF

  if [[ "${assume_yes}" -eq 1 ]]; then
    echo "Type SHRINK USERDATA to continue, or anything else to abort: SHRINK USERDATA"
  else
    printf 'Type SHRINK USERDATA to continue, or anything else to abort: '
    read -r confirm
    [[ "${confirm}" == "SHRINK USERDATA" ]] || exit 0
  fi

  orig_gib=$(( (ud_end_mib - ud_start_mib) / 1024 ))
  min_gib=1
  reserve_gib=8
  max_gib=$(( orig_gib - reserve_gib ))
  (( max_gib >= min_gib )) || fail "not enough userdata space to reserve ${reserve_gib} GiB for Thorch"

  echo "Current Android userdata size: ${orig_gib} GiB"
  echo "Choose how much space Android userdata should keep after it is wiped."
  echo "Allowed range: ${min_gib} GiB to ${max_gib} GiB"
  if [[ "${userdata_keep_gib}" == "auto" || ( -z "${userdata_keep_gib}" && "${assume_yes}" -eq 1 ) ]]; then
    keep_gib=32
    (( keep_gib <= max_gib )) || keep_gib="${max_gib}"
    (( keep_gib >= min_gib )) || keep_gib="${min_gib}"
    echo "Android userdata size in GiB: ${keep_gib}"
  elif [[ -n "${userdata_keep_gib}" ]]; then
    [[ "${userdata_keep_gib}" =~ ^[0-9]+$ ]] || fail "--userdata-keep-gib must be a whole number or auto"
    keep_gib="${userdata_keep_gib}"
    (( keep_gib >= min_gib && keep_gib <= max_gib )) || fail "--userdata-keep-gib must be between ${min_gib} and ${max_gib}"
    echo "Android userdata size in GiB: ${keep_gib}"
  else
    while :; do
      printf 'Android userdata size in GiB: '
      read -r keep_gib
      if [[ "${keep_gib}" =~ ^[0-9]+$ ]] && (( keep_gib >= min_gib && keep_gib <= max_gib )); then
        break
      fi
      echo "Please enter a whole number between ${min_gib} and ${max_gib}."
    done
  fi

  new_ud_end_mib=$(( ud_start_mib + keep_gib * 1024 ))

  cat <<EOF

Thorch will repartition ${disk}:
  Android userdata: partition ${ud_num}, ${keep_gib} GiB, wiped
  ROCKNIX boot:     new 2 GiB partition after userdata
  Thorch root:       new partition using remaining space

EOF
  confirm_or_fail "CREATE THORCH" "Type CREATE THORCH to continue: "

  echo ":: thorch-install phase=resize-userdata"
  parted -s "${disk}" rm "${ud_num}"
  before_nums="$(partition_numbers "${disk}")"
  parted -a optimal -s "${disk}" mkpart primary ext4 "${ud_start_mib}MiB" "${new_ud_end_mib}MiB"
  ud_num="$(new_partition_number_since "${disk}" "${before_nums}")"
  parted -s "${disk}" name "${ud_num}" userdata
  partprobe_wait "${disk}"
  ud_node="$(partition_node "${disk}" "${ud_num}")"
  [[ -b "${ud_node}" ]] || fail "recreated userdata partition did not appear: ${ud_node}"
  dd if=/dev/zero of="${ud_node}" bs=1M count=8 status=none

  create_target_in_free_space_after_userdata "${disk}" "${new_ud_end_mib}" "${disk_mib}"
}

find_thorch_internal_target() {
  local current_base name type fstype label partlabel base
  local boot_candidates=()
  local root_candidates=()
  local boot root pair_count=0

  current_base="$(current_root_base)"

  while read -r name type; do
    [[ "${type}" == "part" ]] || continue
    base="$(base_block "${name}")"
    [[ "${base}" != "${current_base}" ]] || continue
    fstype="$(partition_fstype "${name}")"
    label="$(partition_label "${name}")"
    partlabel="$(partition_partlabel "${name}")"

    if [[ ( "${fstype}" == "vfat" || -z "${fstype}" ) && ( "${label}" == "ROCKNIX" || "${partlabel}" == "ROCKNIX" ) ]]; then
      reject_android_partition "${name}"
      require_unmounted "${name}"
      boot_candidates+=("${name}")
    fi

    if supported_root_fstype "${fstype}" &&
      [[ "${label}" == "THORCH_ROOT" || "${label}" == "armbi_root" || "${partlabel}" == "STORAGE" ]]; then
      reject_android_partition "${name}"
      require_unmounted "${name}"
      root_candidates+=("${name}")
    fi
  done < <(lsblk -nrpo NAME,TYPE)

  for boot in "${boot_candidates[@]}"; do
    for root in "${root_candidates[@]}"; do
      [[ "$(base_block "${boot}")" == "$(base_block "${root}")" ]] || continue
      boot_device="${boot}"
      root_device="${root}"
      pair_count=$((pair_count + 1))
    done
  done

  if [[ "${pair_count}" -eq 1 ]]; then
    return 0
  fi

  if [[ "${pair_count}" -gt 1 ]]; then
    local chosen_boot="" chosen_root="" chosen_count=0 boot_end root_start
    for boot in "${boot_candidates[@]}"; do
      boot_end="$(partition_end "${boot}")" || continue
      for root in "${root_candidates[@]}"; do
        [[ "$(base_block "${boot}")" == "$(base_block "${root}")" ]] || continue
        root_start="$(partition_start "${root}")" || continue
        if [[ -n "${boot_end}" && -n "${root_start}" ]] && (( boot_end == root_start )); then
          chosen_boot="${boot}"
          chosen_root="${root}"
          chosen_count=$((chosen_count + 1))
        fi
      done
    done
    if [[ "${chosen_count}" -eq 1 ]]; then
      boot_device="${chosen_boot}"
      root_device="${chosen_root}"
      return 0
    fi
    fail "found multiple possible internal Thorch targets; rerun with --boot-device and --root-device"
  fi

  local disk
  if [[ "${create_from_userdata}" -eq 1 ]] && (( ${#boot_candidates[@]} > 0 || ${#root_candidates[@]} > 0 )) && disk="$(internal_userdata_disk)"; then
    echo ":: thorch-install phase=create-target"
    create_target_by_reusing_resized_userdata "${disk}" || fail "found a partial internal Thorch target but no reusable post-userdata space"
    return 0
  fi

  if [[ "${create_from_userdata}" -eq 1 ]] && disk="$(internal_userdata_disk)"; then
    echo ":: thorch-install phase=create-target"
    create_target_by_shrinking_userdata "${disk}"
    return 0
  fi

  if [[ "${create_from_userdata}" -eq 1 ]]; then
    fail "no existing Thorch target and no unique Android userdata partition found"
  fi

  fail "no existing Thorch target found; pass --create-from-userdata to shrink/wipe Android userdata and create one"
}

require_unmounted() {
  local dev="$1"
  if findmnt -rn -S "${dev}" >/dev/null 2>&1; then
    fail "${dev} is currently mounted"
  fi
}

mounted_targets=()
cleanup_target_mounts() {
  local mp
  for ((i=${#mounted_targets[@]}-1; i>=0; i--)); do
    mp="${mounted_targets[$i]}"
    if findmnt -rn --mountpoint "${mp}" >/dev/null 2>&1; then
      umount "${mp}" 2>/dev/null || true
    fi
  done
}

mount_target() {
  local dev="$1" mp="$2" options="${3:-}"
  if [[ -n "${options}" ]]; then
    mount -o "${options}" "${dev}" "${mp}"
  else
    mount "${dev}" "${mp}"
  fi
  mounted_targets+=("${mp}")
}

require_target_clear() {
  local mp
  for mp in "${target}/boot" "${target}"; do
    if findmnt -rn --mountpoint "${mp}" >/dev/null 2>&1; then
      fail "target mountpoint is already in use: ${mp}"
    fi
  done
}

normalize_target() {
  target="$(readlink -m "${target}")"
  [[ "${target}" != "/" ]] || fail "--target must not be /"
  case "${target}" in
    /mnt/thorch-internal|/mnt/thorch-internal/*|/run/thorch-installer/*)
      ;;
    *)
      fail "--target must be under /mnt/thorch-internal or /run/thorch-installer"
      ;;
  esac
}

prepare_target_dir() {
  [[ ! -L "${target}" ]] || fail "target must not be a symlink: ${target}"
  if [[ -e "${target}" && ! -d "${target}" ]]; then
    fail "target exists and is not a directory: ${target}"
  fi
  if [[ -d "${target}" ]]; then
    rmdir "${target}" 2>/dev/null || fail "target directory exists and is not empty: ${target}"
  fi
  mkdir -p "${target}"
}

backup_existing_boot() {
  local dev="$1" stamp tmp backup
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  backup="/var/lib/thorch-installer/boot-backups/${stamp}"
  tmp="$(mktemp -d)"
  mkdir -p "${backup}"
  if mount -o ro "${dev}" "${tmp}" 2>/dev/null; then
    rsync -a "${tmp}/" "${backup}/"
    umount "${tmp}"
    echo "existing boot files backed up to ${backup}"
  else
    echo "no readable existing boot filesystem found on ${dev}; skipping boot backup"
  fi
  rmdir "${tmp}"
}

source_cache_tmpfs_fstab_entries() {
  local source_fstab="${1:-/etc/fstab}"

  awk '
    $1 == "tmpfs" && $2 ~ /^\/home\/[^/[:space:]]+\/\.cache$/ && $3 == "tmpfs" {
      print
    }
  ' "${source_fstab}" 2>/dev/null || true
}

ensure_cache_tmpfs_mountpoints() {
  local entries="$1" source mountpoint rest

  [[ -n "${entries}" ]] || return 0
  while read -r source mountpoint rest; do
    [[ -n "${mountpoint}" ]] || continue
    [[ "${mountpoint}" =~ ^/home/[^/[:space:]]+/\.cache$ ]] || continue
    mkdir -p "${target}${mountpoint}"
  done <<< "${entries}"
}

require_root
for cmd in arch-chroot blkid blockdev dd findmnt lsblk mkfs.vfat mount parted partprobe thorch-check-boot thorch-rebuild-abl-kernel readlink rsync sed udevadm umount; do
  need "${cmd}"
done
configure_root_filesystem
normalize_target
is_removable_root || fail "refusing to install: current / does not appear to be booted from removable SD"

if [[ -z "${boot_device}" && -z "${root_device}" ]]; then
  find_thorch_internal_target
elif [[ -z "${boot_device}" || -z "${root_device}" ]]; then
  usage
  fail "pass both --boot-device and --root-device, or pass neither for auto-detect"
fi

[[ -b "${boot_device}" ]] || fail "boot device is not a block device: ${boot_device}"
[[ -b "${root_device}" ]] || fail "root device is not a block device: ${root_device}"
[[ "${boot_device}" != "${root_device}" ]] || fail "boot and root devices must differ"

reject_android_partition "${boot_device}"
reject_android_partition "${root_device}"
require_unmounted "${boot_device}"
require_unmounted "${root_device}"

cat <<EOF
Thorch will install the running system to internal storage:
  boot partition: ${boot_device}  -> FAT32 label ROCKNIX
  root partition: ${root_device}  -> ${root_fstype} label THORCH_ROOT

This formats both selected partitions. It will not flash ABL.
EOF

confirm_or_fail "INSTALL THORCH" "Type INSTALL THORCH to continue: "

backup_existing_boot "${boot_device}"

require_target_clear
prepare_target_dir

echo ":: thorch-install phase=format"
mkfs.vfat -F 32 -n ROCKNIX "${boot_device}"
format_root_device

trap cleanup_target_mounts EXIT

mount_target "${root_device}" "${target}" "${root_mount_options}"
mkdir -p "${target}/boot"
mount_target "${boot_device}" "${target}/boot"

rsync_progress_args=()
if [[ "${THORCH_INSTALL_PROGRESS:-0}" == "1" ]]; then
  rsync_progress_args=(--info=progress2,name0)
fi

cache_tmpfs_fstab_entries="$(source_cache_tmpfs_fstab_entries)"

echo ":: thorch-install phase=copy-root"
rsync -aAXH --numeric-ids \
  "${rsync_progress_args[@]}" \
  --one-file-system \
  --exclude=/dev/* \
  --exclude=/proc/* \
  --exclude=/sys/* \
  --exclude=/run/* \
  --exclude=/tmp/* \
  --exclude=/mnt/* \
  --exclude=/media/* \
  --exclude=/lost+found \
  --exclude=/boot/* \
  / "${target}/"

mkdir -p "${target}"/{dev,proc,sys,run,tmp,mnt,media}
chmod 1777 "${target}/tmp"
ensure_cache_tmpfs_mountpoints "${cache_tmpfs_fstab_entries}"
echo ":: thorch-install phase=copy-boot"
rsync -a "${rsync_progress_args[@]}" /boot/ "${target}/boot/"

root_uuid="$(blkid -s UUID -o value "${root_device}")"
boot_uuid="$(blkid -s UUID -o value "${boot_device}")"

cat > "${target}/etc/fstab" <<EOF
UUID=${root_uuid} / ${root_fstype} ${root_mount_options} 0 ${root_fstab_pass}
UUID=${boot_uuid} /boot vfat rw,relatime,fmask=0022,dmask=0022,codepage=437,iocharset=ascii,shortname=mixed,utf8,errors=remount-ro 0 2
${cache_tmpfs_fstab_entries}
EOF

thorch_mkinitcpio_conf="${target}/etc/mkinitcpio.conf.d/90-thorch.conf"
[[ -f "${thorch_mkinitcpio_conf}" ]] ||
  fail "installed root is missing package-owned Thorch mkinitcpio policy"
grep -Eq '^HOOKS=.*(^|[[:space:](])thorch-sd-prefer([[:space:])]|$)' \
  "${thorch_mkinitcpio_conf}" ||
  fail "Thorch mkinitcpio policy is missing thorch-sd-prefer"
if [[ "${root_fstype}" == "btrfs" ]]; then
  grep -Eq '^MODULES\+?=.*(^|[[:space:](])btrfs([[:space:])]|$)' \
    "${thorch_mkinitcpio_conf}" ||
    fail "Thorch mkinitcpio policy is missing btrfs root support"
fi

echo ":: thorch-install phase=mkinitcpio"
arch-chroot "${target}" mkinitcpio -P
echo ":: thorch-install phase=rebuild-boot"
thorch-rebuild-abl-kernel --boot-dir "${target}/boot" --root-uuid "${root_uuid}" --rootfstype "${root_fstype}"
echo ":: thorch-install phase=check-boot"
thorch-check-boot --boot-dir "${target}/boot" --root-uuid "${root_uuid}"

echo ":: thorch-install phase=sync"
sync
cleanup_target_mounts
trap - EXIT

echo "Thorch internal install complete. Reboot and select the Thor Linux boot path."
