#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: thorch-expand-root [--force] [--yes]

Expand the currently booted ext4 or btrfs root partition to the end of its
parent block device, then grow the mounted filesystem online.

  --force   override removable/Thorch SD root safety checks
  --yes     do not ask for interactive confirmation
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  local missing=0 cmd
  for cmd in "$@"; do
    if ! command -v "${cmd}" >/dev/null 2>&1; then
      printf 'missing required command: %s\n' "${cmd}" >&2
      missing=1
    fi
  done
  [[ "${missing}" -eq 0 ]] || exit 1
}

resolve_block_source() {
  local src="$1"
  src="${src%%[*}"
  if [[ "${src}" == UUID=* || "${src}" == LABEL=* || "${src}" == PARTUUID=* || "${src}" == PARTLABEL=* ]]; then
    src="$(findfs "${src}")"
  fi
  readlink -f "${src}"
}

is_thorch_sd_root() {
  local root_dev="$1" disk_name="$2" disk="$3" boot_source boot_dev boot_parent part_count root_label boot_label

  # Thor's SD slot can report RM=0. Accept only the expected Thorch SD image
  # shape as the fallback: root on mmcblk*, THORCH_ROOT root label, and a
  # ROCKNIX /boot partition on the same two-partition mmc disk.
  [[ "${disk_name}" == mmcblk* ]] || return 1
  part_count="$(lsblk -nrpo TYPE "${disk}" 2>/dev/null | awk '$1 == "part" { count++ } END { print count + 0 }')"
  [[ "${part_count}" == "2" ]] || return 1

  root_label="$(blkid -s LABEL -o value "${root_dev}" 2>/dev/null || true)"
  [[ "${root_label}" == "THORCH_ROOT" ]] || return 1

  boot_source="$(findmnt -no SOURCE /boot 2>/dev/null || true)"
  [[ -n "${boot_source}" ]] || return 1
  boot_dev="$(resolve_block_source "${boot_source}" 2>/dev/null || true)"
  [[ -b "${boot_dev}" ]] || return 1

  boot_parent="$(lsblk -no PKNAME "${boot_dev}" 2>/dev/null | head -n1 | tr -d '[:space:]')"
  [[ "${boot_parent}" == "${disk_name}" ]] || return 1

  boot_label="$(blkid -s LABEL -o value "${boot_dev}" 2>/dev/null || true)"
  [[ "${boot_label}" == "ROCKNIX" ]]
}

force=0
yes=0
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --force)
      force=1
      shift
      ;;
    --yes|-y)
      yes=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      die "unknown argument: $1"
      ;;
  esac
done

[[ "${EUID}" -eq 0 ]] || die "this command must run as root"
require_cmd awk blkid blockdev findfs findmnt lsblk partprobe sfdisk udevadm

root_source="$(findmnt -no SOURCE /)"
root_fstype="$(findmnt -no FSTYPE /)"
case "${root_fstype}" in
  ext4)
    require_cmd resize2fs
    ;;
  btrfs)
    require_cmd btrfs
    ;;
  *)
    die "root filesystem is ${root_fstype}, not ext4 or btrfs"
    ;;
esac

root_source="$(resolve_block_source "${root_source}")"
[[ -b "${root_source}" ]] || die "root source is not a block device: ${root_source}"
root_dev="$(readlink -f "${root_source}")"
[[ -b "${root_dev}" ]] || die "unable to resolve root block device from ${root_source}"

parent_name="$(lsblk -no PKNAME "${root_dev}" | head -n1 | tr -d '[:space:]')"
partno="$(lsblk -no PARTN "${root_dev}" | head -n1 | tr -d '[:space:]')"
[[ -n "${parent_name}" && -n "${partno}" ]] || die "root device ${root_dev} is not a normal disk partition"

disk="/dev/${parent_name}"
[[ -b "${disk}" ]] || die "parent disk does not exist: ${disk}"

removable="$(lsblk -dnro RM "${disk}" | head -n1 | tr -d '[:space:]')"
if [[ "${removable}" != "1" && "${force}" -ne 1 ]] && ! is_thorch_sd_root "${root_dev}" "${parent_name}" "${disk}"; then
  die "${disk} is not marked removable and does not match the expected Thorch SD root layout; pass --force only if this is the intended SD root device"
fi

root_mount_opts="$(findmnt -no OPTIONS /)"
[[ ",${root_mount_opts}," == *,rw,* ]] || die "root filesystem is not mounted read-write"

part_size_before="$(blockdev --getsize64 "${root_dev}")"
disk_bytes="$(blockdev --getsize64 "${disk}")"

cat <<EOF

Root device: ${root_dev}
Parent disk: ${disk}
Partition:   ${partno}
Disk size:   ${disk_bytes} bytes
Root size:   ${part_size_before} bytes

EOF

if [[ "${yes}" -ne 1 ]]; then
  read -r -p "Type EXPAND to grow ${root_dev} to fill ${disk}: " answer
  [[ "${answer}" == "EXPAND" ]] || die "confirmation did not match"
fi

echo "Repairing GPT backup header if the card is larger than the image..."
sfdisk --relocate gpt-bak-std "${disk}" >/dev/null 2>&1 || true

echo "Growing partition ${partno} to the end of ${disk}..."
printf ',+\n' | sfdisk --no-reread -N "${partno}" "${disk}"

partprobe "${disk}" >/dev/null 2>&1 || true
udevadm settle
blockdev --rereadpt "${disk}" >/dev/null 2>&1 || true
udevadm settle

part_size_after="$(blockdev --getsize64 "${root_dev}")"
if [[ "${part_size_after}" -le "${part_size_before}" ]]; then
  echo "No larger partition size is visible yet; running filesystem growth anyway."
  echo "If filesystem growth reports no change and free space remains, reboot and run this launcher again."
fi

case "${root_fstype}" in
  ext4)
    echo "Growing ext4 filesystem on ${root_dev}..."
    resize2fs "${root_dev}"
    ;;
  btrfs)
    echo "Growing btrfs filesystem mounted at /..."
    btrfs filesystem resize max /
    ;;
esac

fs_blocks="$(findmnt -no SIZE /)"
echo
if [[ "${part_size_after}" -gt "${part_size_before}" ]]; then
  echo "Root partition expanded from ${part_size_before} to ${part_size_after} bytes."
else
  echo "Root partition size is ${part_size_after} bytes."
fi
echo "Mounted root filesystem size is now ${fs_blocks}."
