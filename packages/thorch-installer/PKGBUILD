# Maintainer: Thorch contributors

pkgname=thorch-installer
pkgver=1
pkgrel=5
pkgdesc='Thorch internal installer and recovery tooling for AYN Thor'
arch=(aarch64)
license=(GPL-2.0-or-later)
depends=(arch-install-scripts bash btrfs-progs coreutils dosfstools e2fsprogs findutils gawk grep parted rsync systemd util-linux thorch-bsp)
source=()
sha256sums=()

package() {
  cd "${startdir}/payload"
  cp -a . "${pkgdir}/"
  chmod 755 "${pkgdir}/usr/bin/thorch-expand-root"
  chmod 755 "${pkgdir}/usr/bin/thorch-expand-root-launcher"
  chmod 755 "${pkgdir}/usr/bin/thorch-install-internal"
  chmod 755 "${pkgdir}/usr/bin/thorch-install-internal-launcher"
}
