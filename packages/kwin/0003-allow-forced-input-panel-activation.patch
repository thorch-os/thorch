@@ -273,0 +275,28 @@ void InputMethodTest::testInputPanelPlacement()
+void InputMethodTest::testForceActivate()
+{
+    // Xwayland clients cannot advertise text-input-v2/v3 support. The mobile
+    // navigation panel must still be able to force the keyboard open even if
+    // automatic virtual-keyboard activation is disabled.
+    std::unique_ptr<KWayland::Client::Surface> surface(Test::createSurface());
+    std::unique_ptr<Test::XdgToplevel> shellSurface(Test::createXdgToplevelSurface(surface.get()));
+    Window *window = Test::renderAndWaitForShown(surface.get(), QSize(800, 600), Qt::red);
+    QVERIFY(window);
+    QVERIFY(!kwinApp()->inputMethod()->activeClientSupportsTextInput());
+
+    kwinApp()->inputMethod()->setMode(InputMethod::VirtualKeyboardVisibility::Never);
+    QSignalSpy activateSpy(Test::inputMethod(), &Test::MockInputMethod::activate);
+    kwinApp()->inputMethod()->forceActivate();
+
+    QVERIFY(activateSpy.count() || activateSpy.wait());
+    QTRY_VERIFY(kwinApp()->inputMethod()->panel());
+    Window *keyboardClient = kwinApp()->inputMethod()->panel();
+    QVERIFY(keyboardClient);
+    QVERIFY(keyboardClient->isInputMethod());
+    QTRY_VERIFY(kwinApp()->inputMethod()->isVisible());
+
+    kwinApp()->inputMethod()->setActive(false);
+    QTRY_VERIFY(!kwinApp()->inputMethod()->isVisible());
+    shellSurface.reset();
+    QVERIFY(Test::waitForWindowClosed(window));
+}
+
