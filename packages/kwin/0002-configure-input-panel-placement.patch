+void InputMethodTest::testInputPanelPlacement()
+{
+    const auto outputs = workspace()->outputs();
+    QCOMPARE(outputs.size(), 2);
+
+    KConfigGroup waylandGroup = kwinApp()->config()->group(QStringLiteral("Wayland"));
+    waylandGroup.writeEntry("InputPanelPlacement", QStringLiteral("Auto"));
+    kwinApp()->config()->sync();
+
+    std::unique_ptr<KWayland::Client::Surface> surface(Test::createSurface());
+    std::unique_ptr<Test::XdgToplevel> shellSurface(Test::createXdgToplevelSurface(surface.get()));
+    Window *window = Test::renderAndWaitForShown(surface.get(), QSize(800, 600), Qt::red);
+    QVERIFY(window);
+    QCOMPARE(window->output(), outputs[0]);
+
+    // Request the same output as the text field. Auto must override that request
+    // and place the keyboard on the other output.
+    Test::inputMethod()->setOutputIndex(0);
+    std::unique_ptr<KWayland::Client::TextInput> textInput(Test::waylandTextInputManager()->createTextInput(Test::waylandSeat()));
+    QSignalSpy windowAddedSpy(workspace(), &Workspace::windowAdded);
+    textInput->enable(surface.get());
+    textInput->showInputPanel();
+    QVERIFY(windowAddedSpy.wait());
+
+    Window *keyboardClient = windowAddedSpy.last().first().value<Window *>();
+    QVERIFY(keyboardClient);
+    QVERIFY(keyboardClient->isInputMethod());
+    QTRY_COMPARE(keyboardClient->output(), outputs[1]);
+
+    waylandGroup.writeEntry("InputPanelPlacement", QStringLiteral("Top"), KConfig::Notify);
+    kwinApp()->config()->sync();
+    workspace()->slotReconfigure();
+    QTRY_COMPARE(keyboardClient->output(), outputs[0]);
+
+    waylandGroup.writeEntry("InputPanelPlacement", QStringLiteral("Bottom"), KConfig::Notify);
+    kwinApp()->config()->sync();
+    workspace()->slotReconfigure();
+    QTRY_COMPARE(keyboardClient->output(), outputs[1]);
+
+    waylandGroup.writeEntry("InputPanelPlacement", QStringLiteral("Auto"), KConfig::Notify);
+    kwinApp()->config()->sync();
+    workspace()->slotReconfigure();
+    QTRY_COMPARE(keyboardClient->output(), outputs[1]);
+
+    // Auto follows the text-input window if it moves to the other output.
+    window->sendToOutput(outputs[1]);
+    QTRY_COMPARE(window->output(), outputs[1]);
+    QTRY_COMPARE(keyboardClient->output(), outputs[0]);
+
+    shellSurface.reset();
+    QVERIFY(Test::waitForWindowClosed(window));
 }

