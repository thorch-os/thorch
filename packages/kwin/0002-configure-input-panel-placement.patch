+void InputPanelV1Window::updatePlacementWindow()
+{
+    disconnect(m_placementWindowOutputConnection);
+
+    Window *typingWindow = kwinApp()->inputMethod()->activeWindow();
+    if (!typingWindow) {
+        typingWindow = workspace()->activeWindow();
+    }
+    if (typingWindow) {
+        m_placementWindowOutputConnection = connect(typingWindow, &Window::outputChanged, this, &InputPanelV1Window::reposition);
+    }
+
+    reposition();
+}
+
+LogicalOutput *InputPanelV1Window::placementOutput() const
+{
+    const QList<LogicalOutput *> outputs = workspace()->outputs();
+    if (outputs.isEmpty()) {
+        return m_requestedOutput ? m_requestedOutput.data() : workspace()->activeOutput();
+    }
+    if (outputs.size() == 1) {
+        return outputs.constFirst();
+    }
+
+    QList<LogicalOutput *> orderedOutputs = outputs;
+    std::ranges::stable_sort(orderedOutputs, [](const LogicalOutput *left, const LogicalOutput *right) {
+        const QPointF leftCenter = left->geometry().center();
+        const QPointF rightCenter = right->geometry().center();
+        if (leftCenter.y() != rightCenter.y()) {
+            return leftCenter.y() < rightCenter.y();
+        }
+        return leftCenter.x() < rightCenter.x();
+    });
+
+    const QString placement = kwinApp()->config()
+                                  ->group(QStringLiteral("Wayland"))
+                                  .readEntry("InputPanelPlacement", QStringLiteral("Auto"))
+                                  .trimmed();
+    if (placement.compare(QLatin1StringView("Top"), Qt::CaseInsensitive) == 0) {
+        return orderedOutputs.constFirst();
+    }
+    if (placement.compare(QLatin1StringView("Bottom"), Qt::CaseInsensitive) == 0) {
+        return orderedOutputs.constLast();
+    }
+
+    Window *typingWindow = kwinApp()->inputMethod()->activeWindow();
+    if (!typingWindow) {
+        typingWindow = workspace()->activeWindow();
+    }
+    if (outputs.size() == 2 && typingWindow && outputs.contains(typingWindow->output())) {
+        return outputs.constFirst() == typingWindow->output() ? outputs.constLast() : outputs.constFirst();
+    }
+
+    if (m_requestedOutput && outputs.contains(m_requestedOutput.data())) {
+        return m_requestedOutput.data();
+    }
+    return orderedOutputs.constLast();
+}
