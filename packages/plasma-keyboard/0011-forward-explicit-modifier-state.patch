+std::optional<Keyboard::ModifierState> Keyboard::modifierStateWith(Qt::KeyboardModifiers modifiers) const
+{
+    if (!mXkbKeymap || !mXkbState) {
+        return std::nullopt;
+    }
+
+    QXkbCommon::ScopedXKBState state(xkb_state_new(mXkbKeymap.get()));
+    if (!state) {
+        return std::nullopt;
+    }
+
+    const auto locked = xkb_state_serialize_mods(mXkbState.get(), XKB_STATE_MODS_LOCKED);
+    const auto group = xkb_state_serialize_layout(mXkbState.get(), XKB_STATE_LAYOUT_EFFECTIVE);
+    // KWin echoes modifier requests back through the keyboard grab. Do not
+    // seed depressed or latched state from that grab, otherwise a synthetic
+    // Ctrl/Shift chord becomes the baseline and cannot be released cleanly.
+    // The QKeyEvent contains the complete active chord; only lock and layout
+    // state need to survive between requests.
+    xkb_state_update_mask(state.get(), 0, 0, locked, 0, 0, group);
+
+    const auto pressModifier = [this, &state](xkb_keysym_t keysym) {
+        const auto code = keyCodeForKeysym(keysym);
+        if (!code) {
+            return false;
+        }
+        xkb_state_update_key(state.get(), *code + 8, XKB_KEY_DOWN);
+        return true;
+    };
+
+    if ((modifiers & Qt::ControlModifier) && !pressModifier(XKB_KEY_Control_L)) {
+        return std::nullopt;
+    }
+    if ((modifiers & Qt::AltModifier) && !pressModifier(XKB_KEY_Alt_L)) {
+        return std::nullopt;
+    }
+    if ((modifiers & Qt::MetaModifier) && !pressModifier(XKB_KEY_Super_L)) {
+        return std::nullopt;
+    }
+    if ((modifiers & Qt::GroupSwitchModifier) && !pressModifier(XKB_KEY_ISO_Level3_Shift)) {
+        return std::nullopt;
+    }
+    if ((modifiers & Qt::ShiftModifier) && !pressModifier(XKB_KEY_Shift_L)) {
+        return std::nullopt;
+    }
+
+    return ModifierState{
+        .depressed = xkb_state_serialize_mods(state.get(), XKB_STATE_MODS_DEPRESSED),
+        .latched = xkb_state_serialize_mods(state.get(), XKB_STATE_MODS_LATCHED),
+        .locked = xkb_state_serialize_mods(state.get(), XKB_STATE_MODS_LOCKED),
+        .group = xkb_state_serialize_layout(state.get(), XKB_STATE_LAYOUT_EFFECTIVE),
+    };
+}
