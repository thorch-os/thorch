+bool InputPlugin::setModifiers(Qt::KeyboardModifiers modifiers) const
+{
+    if (!m_context || !m_keyboard) {
+        return false;
+    }
+
+    const auto state = m_keyboard->modifierStateWith(modifiers);
+    if (!state) {
+        return false;
+    }
+
+    m_context->modifiers(m_context->m_latestSerial, state->depressed, state->latched, state->locked, state->group);
+    return true;
+}
