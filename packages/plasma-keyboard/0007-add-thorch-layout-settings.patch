+QString PlasmaKeyboardKcm::panelPlacement() const
+{
+    return m_panelPlacement;
+}
+
+void PlasmaKeyboardKcm::setPanelPlacement(const QString &panelPlacement)
+{
+    const QString normalizedPlacement = normalizedPanelPlacement(panelPlacement);
+    if (normalizedPlacement == m_panelPlacement) {
+        return;
+    }
+
+    m_panelPlacement = normalizedPlacement;
+    Q_EMIT panelPlacementChanged();
+
+    setNeedsSave(true);
+}
