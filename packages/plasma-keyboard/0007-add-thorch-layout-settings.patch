+QString normalizedPanelPlacement(const QString &placement)
+{
+    if (placement.compare(QLatin1StringView("Top"), Qt::CaseInsensitive) == 0) {
+        return QStringLiteral("Top");
+    }
+    if (placement.compare(QLatin1StringView("Bottom"), Qt::CaseInsensitive) == 0) {
+        return QStringLiteral("Bottom");
+    }
+    return QStringLiteral("Auto");
+}
+}
