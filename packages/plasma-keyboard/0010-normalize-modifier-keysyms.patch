+#include <linux/input-event-codes.h>
+
+class KeycodeHelperTest : public QObject
+{
+    Q_OBJECT
+
+private Q_SLOTS:
+    void mapsUnicodeEncodedLatinKeysym()
+    {
+        xkb_context *context = xkb_context_new(XKB_CONTEXT_NO_FLAGS);
+        QVERIFY(context);
+
+        const xkb_rule_names names = {
+            .rules = "evdev",
+            .model = "pc105",
+            .layout = "us",
+        };
+        xkb_keymap *keymap = xkb_keymap_new_from_names(context, &names, XKB_KEYMAP_COMPILE_NO_FLAGS);
+        QVERIFY(keymap);
+        xkb_state *state = xkb_state_new(keymap);
+        QVERIFY(state);
+
+        // This is how QXkbCommon::toKeysym() encodes a text-empty Qt::Key_C.
+        const auto upperCode = PlasmaKeyboard::keyCodeForKeysym(keymap, state, 0x01000043);
+        const auto lowerCode = PlasmaKeyboard::keyCodeForKeysym(keymap, state, 0x01000063);
+        QVERIFY(upperCode.has_value());
+        QVERIFY(lowerCode.has_value());
+        QCOMPARE(*upperCode, uint32_t(KEY_C));
+        QCOMPARE(*lowerCode, uint32_t(KEY_C));
+
+        xkb_state_unref(state);
+        xkb_keymap_unref(keymap);
+        xkb_context_unref(context);
+    }
+
+    void mapsModifierKeysyms()
+    {
+        xkb_context *context = xkb_context_new(XKB_CONTEXT_NO_FLAGS);
+        QVERIFY(context);
+
+        const xkb_rule_names names = {
+            .rules = "evdev",
+            .model = "pc105",
+            .layout = "us",
+        };
+        xkb_keymap *keymap = xkb_keymap_new_from_names(context, &names, XKB_KEYMAP_COMPILE_NO_FLAGS);
+        QVERIFY(keymap);
+        xkb_state *state = xkb_state_new(keymap);
+        QVERIFY(state);
+
+        const auto controlCode = PlasmaKeyboard::keyCodeForKeysym(keymap, state, XKB_KEY_Control_L);
+        const auto shiftCode = PlasmaKeyboard::keyCodeForKeysym(keymap, state, XKB_KEY_Shift_L);
+        QVERIFY(controlCode.has_value());
+        QVERIFY(shiftCode.has_value());
+        QCOMPARE(*controlCode, uint32_t(KEY_LEFTCTRL));
+        QCOMPARE(*shiftCode, uint32_t(KEY_LEFTSHIFT));
+
+        xkb_state_unref(state);
+        xkb_keymap_unref(keymap);
+        xkb_context_unref(context);
+    }
+};
+
+QTEST_GUILESS_MAIN(KeycodeHelperTest)
+
+#include "keycodehelpertest.moc"
