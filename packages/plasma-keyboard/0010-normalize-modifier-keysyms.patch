diff --git a/src/keycodehelper_p.h b/src/keycodehelper_p.h
new file mode 100644
index 0000000..d8132bd
--- /dev/null
+++ b/src/keycodehelper_p.h
@@ -0,0 +1,83 @@
+/*
+    SPDX-FileCopyrightText: 2026 Thorch contributors
+
+    SPDX-License-Identifier: LGPL-2.1-only OR LGPL-3.0-only OR LicenseRef-KDE-Accepted-LGPL
+*/
+
+#pragma once
+
+#include <array>
+#include <optional>
+
+#include <xkbcommon/xkbcommon.h>
+
+namespace PlasmaKeyboard
+{
+
+inline xkb_keysym_t canonicalKeysym(xkb_keysym_t keysym)
+{
+    // QXkbCommon::toKeysym() represents text-empty printable QKeyEvents as
+    // Unicode keysyms. XKB keymaps use the legacy value for Latin-1 symbols,
+    // so canonicalize before looking the symbol up in the keymap.
+    constexpr xkb_keysym_t unicodePrefix = 0x01000000;
+    constexpr xkb_keysym_t unicodeMask = 0xff000000;
+    if ((keysym & unicodeMask) == unicodePrefix) {
+        return xkb_utf32_to_keysym(keysym & ~unicodeMask);
+    }
+    return keysym;
+}
+
+inline std::optional<uint32_t> keyCodeForKeysym(xkb_keymap *keymap, xkb_state *state, xkb_keysym_t keysym)
+{
+    if (!keymap || !state) {
+        return std::nullopt;
+    }
+
+    const xkb_keysym_t canonical = canonicalKeysym(keysym);
+    const std::array candidates = {
+        canonical,
+        xkb_keysym_to_lower(canonical),
+        xkb_keysym_to_upper(canonical),
+    };
+
+    const auto findInLayout = [keymap, &candidates](xkb_layout_index_t layout) -> std::optional<uint32_t> {
+        const xkb_keycode_t minKeycode = xkb_keymap_min_keycode(keymap);
+        const xkb_keycode_t maxKeycode = xkb_keymap_max_keycode(keymap);
+
+        for (xkb_keycode_t keycode = minKeycode; keycode <= maxKeycode; ++keycode) {
+            const xkb_level_index_t levelCount = xkb_keymap_num_levels_for_key(keymap, keycode, layout);
+            for (xkb_level_index_t level = 0; level < levelCount; ++level) {
+                const xkb_keysym_t *symbols = nullptr;
+                const int symbolCount = xkb_keymap_key_get_syms_by_level(keymap, keycode, layout, level, &symbols);
+                for (int index = 0; index < symbolCount; ++index) {
+                    for (const xkb_keysym_t candidate : candidates) {
+                        if (symbols[index] == candidate && keycode >= 8) {
+                            return keycode - 8;
+                        }
+                    }
+                }
+            }
+        }
+
+        return std::nullopt;
+    };
+
+    const xkb_layout_index_t effectiveLayout = xkb_state_serialize_layout(state, XKB_STATE_LAYOUT_EFFECTIVE);
+    if (const auto code = findInLayout(effectiveLayout)) {
+        return code;
+    }
+
+    const xkb_layout_index_t layoutCount = xkb_keymap_num_layouts(keymap);
+    for (xkb_layout_index_t layout = 0; layout < layoutCount; ++layout) {
+        if (layout == effectiveLayout) {
+            continue;
+        }
+        if (const auto code = findInLayout(layout)) {
+            return code;
+        }
+    }
+
+    return std::nullopt;
+}
+
+}
