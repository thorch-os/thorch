+bool InputListenerItem::forwardModifiedKeyEvent(QKeyEvent *event, InputPlugin::KeyState state)
+{
+    constexpr Qt::KeyboardModifiers chordModifiers =
+        Qt::ShiftModifier | Qt::ControlModifier | Qt::AltModifier | Qt::MetaModifier | Qt::GroupSwitchModifier;
+    if (!(event->modifiers() & chordModifiers)) {
+        return false;
+    }
+
+    const QList<xkb_keysym_t> keySymbols = QXkbCommon::toKeysym(event);
+    QList<quint32> keyCodes;
+    keyCodes.reserve(keySymbols.size());
+
+    for (const xkb_keysym_t symbol : keySymbols) {
+        const auto code = m_input.keyCodeForKeysym(symbol);
+        if (!code) {
+            return false;
+        }
+        keyCodes.append(*code);
+    }
+
+    if (state == InputPlugin::Pressed) {
+        if (!m_input.setModifiers(event->modifiers() & chordModifiers)) {
+            return false;
+        }
+        for (const quint32 code : keyCodes) {
+            m_input.key(InputPlugin::Pressed, code);
+        }
+    } else {
+        for (auto code = keyCodes.crbegin(); code != keyCodes.crend(); ++code) {
+            m_input.key(InputPlugin::Released, *code);
+        }
+        m_input.setModifiers(Qt::NoModifier);
+    }
+
+    return true;
+}
