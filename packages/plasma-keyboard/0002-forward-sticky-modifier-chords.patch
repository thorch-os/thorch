+std::optional<uint32_t> Keyboard::keyCodeForKeysym(xkb_keysym_t keysym) const
+{
+    if (!mXkbKeymap || !mXkbState) {
+        return std::nullopt;
+    }
+
+    const xkb_layout_index_t layout = xkb_state_serialize_layout(mXkbState.get(), XKB_STATE_LAYOUT_EFFECTIVE);
+    const xkb_keycode_t minKeycode = xkb_keymap_min_keycode(mXkbKeymap.get());
+    const xkb_keycode_t maxKeycode = xkb_keymap_max_keycode(mXkbKeymap.get());
+
+    for (xkb_keycode_t keycode = minKeycode; keycode <= maxKeycode; ++keycode) {
+        const xkb_level_index_t levelCount = xkb_keymap_num_levels_for_key(mXkbKeymap.get(), keycode, layout);
+        for (xkb_level_index_t level = 0; level < levelCount; ++level) {
+            const xkb_keysym_t *symbols = nullptr;
+            const int symbolCount = xkb_keymap_key_get_syms_by_level(mXkbKeymap.get(), keycode, layout, level, &symbols);
+            for (int index = 0; index < symbolCount; ++index) {
+                if (symbols[index] == keysym && keycode >= 8) {
+                    return keycode - 8;
+                }
+            }
+        }
+    }
+
+    return std::nullopt;
+}
