diff --git a/src/qmlplugin/BreezeKeyPanel.qml b/src/qmlplugin/BreezeKeyPanel.qml
index dbc7710..15fe798 100644
--- a/src/qmlplugin/BreezeKeyPanel.qml
+++ b/src/qmlplugin/BreezeKeyPanel.qml
@@ -22,6 +22,22 @@ KeyPanel {

     readonly property int accent: control && control.thorchAccent !== undefined ? control.thorchAccent : 0

+    readonly property color borderColor: {
+        if (control && control.pressed) {
+            return BreezeConstants.pressedKeyBorderColor;
+        } else if (control && control.highlighted) {
+            return BreezeConstants.highlightedKeyBorderColor;
+        } else if (accent === 1) {
+            return BreezeConstants.modifierKeyBorderColor;
+        } else if (accent === 2) {
+            return BreezeConstants.actionKeyBorderColor;
+        }
+        return BreezeConstants.normalKeyBorderColor;
+    }
+    readonly property real borderWidth: control && control.highlighted
+        ? Math.max(2, BreezeConstants.keyBorderWidth)
+        : BreezeConstants.keyBorderWidth
+
     property color color: {
         if (control && control.pressed) {
             return BreezeConstants.normalKeyPressedBackgroundColor;
@@ -46,10 +62,39 @@ KeyPanel {
             color: root.color
             radius: root.radius

+            border.color: root.borderColor
+            border.width: root.borderWidth
+
             // Shadow
-            shadow.color: Qt.rgba(0, 0, 0, 0.2)
+            shadow.color: Qt.rgba(0, 0, 0, 0.5)
             shadow.size: 2
             shadow.yOffset: 1
+
+            Rectangle {
+                anchors {
+                    top: parent.top
+                    left: parent.left
+                    right: parent.right
+                    topMargin: Math.max(2, root.radius / 3)
+                    leftMargin: root.radius
+                    rightMargin: root.radius
+                }
+                height: Math.max(1, Math.round(BreezeConstants.scaleHint))
+                color: Qt.rgba(1, 1, 1, 0.08)
+            }
+        }
+
+        Rectangle {
+            visible: root.control && root.control.highlighted && root.accent === 1
+            anchors {
+                top: parent.top
+                left: parent.left
+                margins: Math.max(5, Math.round(7 * BreezeConstants.scaleHint))
+            }
+            width: Math.max(5, Math.round(6 * BreezeConstants.scaleHint))
+            height: width
+            radius: width / 2
+            color: BreezeConstants.highlightedKeyBorderColor
         }
     }

