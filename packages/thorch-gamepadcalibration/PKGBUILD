# Maintainer: Thorch contributors

pkgname=thorch-gamepadcalibration
_commit=2077e7af7e9a8c1df54af6f1959cb92daea03207
pkgver=2024.10.02
pkgrel=3
pkgdesc='ROCKNIX GPcal and gamepad testing tools for Thorch'
arch=(any)
url='https://github.com/cdeletre/GPcal'
license=(MIT)
depends=(bash python sdl2 xdg-utils)
makedepends=(tar)
provides=(gamepadcalibration)
options=(!strip)
source=("${pkgname}-${_commit}.tar.gz::https://github.com/cdeletre/GPcal/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/GPcal-${_commit}"

  local target_file="gpcal/gamedata/Klib/RPocket.py"
  [[ -f "${target_file}" ]] || {
    echo "missing ${target_file}" >&2
    return 1
  }

  sed -i \
    -e 's|/sys/module/retroid/parameters|/sys/module/rsinput/parameters|g' \
    -e '/savefile.write(f"echo 1 > {self.parameters_dir}\/update_params\\n")/a\            savefile.write("# Restart InputPlumber\\n")\n            savefile.write("systemctl restart inputplumber\\n")' \
    "${target_file}"
}

package() {
  cd "${srcdir}/GPcal-${_commit}"

  install -d "${pkgdir}/usr/share/gpcal" "${pkgdir}/usr/bin"
  tar --no-same-owner -xzf rocknix/gpcal-python-3.13.tgz -C "${pkgdir}/usr/share"

  sed -i \
    -e 's|/sys/module/retroid/parameters|/sys/module/rsinput/parameters|g' \
    -e '/savefile.write(f"echo 1 > {self.parameters_dir}\/update_params\\n")/a\            savefile.write("# Restart InputPlumber\\n")\n            savefile.write("systemctl restart inputplumber\\n")' \
    "${pkgdir}/usr/share/gpcal/Klib/RPocket.py"

  chmod 0755 "${pkgdir}/usr/share/gpcal/main.py"

  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  cp -a "${startdir}/payload/." "${pkgdir}/"
  ln -s thorch-start-gpcal "${pkgdir}/usr/bin/gpcal"
}
