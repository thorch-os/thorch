+static int tx_macro_validate_dmic_sample_rate(struct tx_macro *tx,
+					      u32 dmic_sample_rate)
+{
+	u32 div_factor;
+
+	if (!dmic_sample_rate || MCLK_FREQ % dmic_sample_rate)
+		goto undefined_rate;
+
+	div_factor = MCLK_FREQ / dmic_sample_rate;
+
+	switch (div_factor) {
+	case 2:
+		tx->dmic_clk_div = TX_MACRO_CLK_DIV_2;
+		break;
+	case 3:
+		tx->dmic_clk_div = TX_MACRO_CLK_DIV_3;
+		break;
+	case 4:
+		tx->dmic_clk_div = TX_MACRO_CLK_DIV_4;
+		break;
+	case 6:
+		tx->dmic_clk_div = TX_MACRO_CLK_DIV_6;
+		break;
+	case 8:
+		tx->dmic_clk_div = TX_MACRO_CLK_DIV_8;
+		break;
+	case 16:
+		tx->dmic_clk_div = TX_MACRO_CLK_DIV_16;
+		break;
+	default:
+		goto undefined_rate;
+	}
+
+	return 0;
+
+undefined_rate:
+	dev_err(tx->dev, "%s: Invalid rate %u, for mclk %d\n",
+		__func__, dmic_sample_rate, MCLK_FREQ);
+
+	return -EINVAL;
+}
