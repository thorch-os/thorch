# Maintainer: Thorch contributors

pkgname=linux-thorch
pkgver=7.1.2
pkgrel=5
pkgdesc='Thorch-packaged ROCKNIX Linux kernel artifacts for AYN Thor / Qualcomm SM8550'
arch=(aarch64)
url='https://github.com/ROCKNIX/distribution'
license=(GPL-2.0-only)
depends=(coreutils kmod mkinitcpio 'thorch-boot-bootstrap-ready>=1-1' 'thorch-bsp>=1-27')
makedepends=(python)
provides=("linux=${pkgver}" "linux-aarch64=${pkgver}")
conflicts=(linux linux-aarch64)
replaces=(linux linux-aarch64)
options=('!strip')

_kernel_dir="${THORCH_ROCKNIX_KERNEL_DIR:-${startdir}/../../vendor/rocknix-kernel}"

verify_waydroid_kernel_config() {
  local image="$1"

  [[ "${THORCH_WAYDROID_KERNEL_REQUIRED:-1}" != "0" ]] || return 0
  if ! /usr/lib/thorch/boot_image.py check-config \
      "${image}" "${startdir}/waydroid-kernel.config"; then
    printf '%s\n' \
      'Rebuild/import a kernel with Binder IPC and BinderFS enabled, or set' \
      'THORCH_WAYDROID_KERNEL_REQUIRED=0 for a local non-Waydroid experiment.' >&2
    return 1
  fi
}

verify_waydroid_module_tree() {
  local modules_dir="$1"
  local missing=()
  local module
  local required_modules=(
    kernel/net/ipv4/netfilter/nf_defrag_ipv4.ko
    kernel/net/ipv6/netfilter/nf_defrag_ipv6.ko
    kernel/net/netfilter/nf_conntrack.ko
    kernel/net/netfilter/nf_nat.ko
    kernel/net/netfilter/nft_chain_nat.ko
    kernel/net/netfilter/nft_masq.ko
    kernel/net/netfilter/nft_nat.ko
  )

  for module in "${required_modules[@]}"; do
    [[ -f "${modules_dir}/${module}" ]] || missing+=("${module}")
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    printf 'linux-thorch is missing Waydroid network module support:\n' >&2
    printf '  %s\n' "${missing[@]}" >&2
    printf 'Rebuild/import a kernel module tree with nftables NAT support.\n' >&2
    exit 1
  fi
}

package() {
  local image="${_kernel_dir}/boot/Image"
  local kernel_boot="${_kernel_dir}/boot/KERNEL"
  local modules_root="${_kernel_dir}/usr/lib/modules"
  local kernver expected_kernver

  if [[ ! -f "${image}" || ! -f "${kernel_boot}" || ! -d "${modules_root}" ]]; then
    cat >&2 <<EOF
Missing ROCKNIX kernel artifacts at:
  ${_kernel_dir}

Expected:
  boot/Image
  boot/KERNEL
  usr/lib/modules/<kernel-release>/

Import them from a mounted or extracted ROCKNIX image first:
  ./scripts/import-rocknix-kernel.sh --from-dir <rocknix-root-or-mount>
EOF
    exit 1
  fi

  verify_waydroid_kernel_config "${image}"

  kernver="$(find "${modules_root}" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort | head -n1)"
  [[ -n "${kernver}" ]] || {
    echo "unable to determine kernel release from ${modules_root}" >&2
    exit 1
  }
  expected_kernver="${pkgver}-thorch${pkgrel}"
  [[ "${kernver}" == "${expected_kernver}" ]] || {
    printf 'linux-thorch kernel release is %s, expected %s; rebuild the kernel after every package release bump\n' \
      "${kernver}" "${expected_kernver}" >&2
    exit 1
  }

  install -Dm644 "${image}" "${pkgdir}/usr/lib/modules/${kernver}/Image"

  cp -a "${modules_root}/${kernver}/." "${pkgdir}/usr/lib/modules/${kernver}/"
  find "${pkgdir}/usr/lib/modules/${kernver}" -name build -type l -delete
  find "${pkgdir}/usr/lib/modules/${kernver}" -name source -type l -delete
  verify_waydroid_module_tree "${pkgdir}/usr/lib/modules/${kernver}"

  install -Dm644 "${kernel_boot}" "${pkgdir}/usr/share/thorch/rocknix/KERNEL"
  if [[ -f "${_kernel_dir}/PROVENANCE" ]]; then
    install -Dm644 "${_kernel_dir}/PROVENANCE" "${pkgdir}/usr/share/licenses/${pkgname}/ROCKNIX-KERNEL-PROVENANCE"
  fi

  install -Dm644 /dev/stdin "${pkgdir}/etc/mkinitcpio.d/linux-thorch.preset" <<EOF
ALL_kver="/usr/lib/modules/${kernver}/Image"
PRESETS=('default' 'fallback')
default_image="/boot/initramfs-linux-thorch.img"
fallback_image="/boot/initramfs-linux-thorch-fallback.img"
fallback_options="-S autodetect"
EOF
}
