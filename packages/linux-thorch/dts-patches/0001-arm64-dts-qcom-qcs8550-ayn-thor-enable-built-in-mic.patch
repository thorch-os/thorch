From 7bf638771e7d26226eab92ab05f9d776ffdd8dde Mon Sep 17 00:00:00 2001
From: Thorch Developers <thorch@local>
Date: Sat, 9 May 2026 00:45:00 +1200
Subject: [PATCH] arm64: dts: qcom: qcs8550-ayn-thor: enable built-in mic

Thor's built-in microphone is routed through the WCD938x digital mic path on
SoundWire, not the AMIC2 analog path used by headset-style capture. Override
Thor's capture link to use the first capture DAI exposed by swr2 and add the
board route for the verified DMIC3/SWR input.
---
 arch/arm64/boot/dts/qcom/qcs8550-ayn-thor.dts | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/qcs8550-ayn-thor.dts b/arch/arm64/boot/dts/qcom/qcs8550-ayn-thor.dts
index c2a3290..4433ea8 100644
--- a/arch/arm64/boot/dts/qcom/qcs8550-ayn-thor.dts
+++ b/arch/arm64/boot/dts/qcom/qcs8550-ayn-thor.dts
@@ -159,6 +159,23 @@
 	};
 };
 
+&{/sound} {
+	model = "AYN-Thor";
+	audio-routing =
+			"IN1_HPHL", "HPHL_OUT",
+			"IN2_HPHR", "HPHR_OUT",
+			"AMIC2", "MIC BIAS2",
+			"TX SWR_INPUT1", "ADC2_OUTPUT",
+			"DMIC3", "MIC BIAS3",
+			"TX SWR_INPUT7", "DMIC3_OUTPUT";
+
+	wcd-capture-dai-link {
+		codec {
+			sound-dai = <&wcd938x 1>, <&swr2 1>, <&lpass_txmacro 0>;
+		};
+	};
+};
+
 &display_panel {
 	compatible = "chipone,icna3520";
 
-- 
