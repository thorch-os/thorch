#!/usr/bin/env bash
set -euo pipefail

steam_root="${STEAM_STORAGE_ROOT:-${HOME}}/.local/share/Steam"
steam_branch="${THORCH_STEAM_BRANCH:-}"
runtime_lib_dir=""
support_bin_dir="${steam_root}/thorch-steamos-bin"
wget_retry=(
  -c
  --tries=20
  --waitretry=15
  --retry-connrefused
  --read-timeout=30
  --timeout=30
  --retry-on-http-error=408,429,500,502,503,504
)
mkdir -p "${steam_root}" "${steam_root}/package" "${HOME}/.steam"
if [[ -z "${steam_branch}" ]]; then
  steam_branch="publicbeta"
fi
echo "${steam_branch}" > "${steam_root}/package/beta"

replace_symlink() {
  local link="$2" target="$1"

  [[ ! -e "${link}" || -L "${link}" ]] || return 1
  rm -f -- "${link}"
  ln -s -- "${target}" "${link}"
}

install_steam_registry() {
  local registry system_steam

  system_steam="${THORCH_STEAM_SYSTEM_DIR:-/usr/share/steam}"
  [[ -f "${system_steam}/registry.vdf" ]] || return 0
  registry="${HOME}/.steam/registry.vdf"
  [[ ! -e "${registry}" && ! -L "${registry}" ]] || return 0
  mkdir -p "${HOME}/.steam"
  python3 - "${system_steam}/registry.vdf" "${registry}" "${steam_root}" <<'PY'
import pathlib
import sys

src = pathlib.Path(sys.argv[1])
dst = pathlib.Path(sys.argv[2])
steam_root = sys.argv[3]
text = src.read_text(encoding="utf-8").replace("@STEAM_LIBRARY@", steam_root)
dst.write_text(text, encoding="utf-8")
PY
}

repair_steam_arm64_runtime_links() {
  local dst lib runtime_lib_dir target
  # ROCKNIX has real GTK2 in the base image, but Arch ARM only has gtk2-compat,
  # which does not provide Steam's legacy GTK2 sonames. ROCKNIX also ships some
  # older multimedia sonames globally, while Arch often has newer ABI names.
  # Keep the launch environment narrow by exposing only the known Steam ARM64
  # compatibility sonames in a small shim directory.
  local -a runtime_libs=(
    libibus-1.0.so.5
    libgtk-x11-2.0.so.0
    libgdk-x11-2.0.so.0
  )
  local -a client_libs=(
    libvpx.so.6
  )

  dst="${steam_root}/lib/aarch64-linux-gnu"
  mkdir -p "${dst}"

  runtime_lib_dir="$(find "${steam_root}/steam-runtime-steamrt-arm64" -path '*/files/lib/aarch64-linux-gnu' -type d -print -quit 2>/dev/null || true)"
  if [[ -n "${runtime_lib_dir}" ]]; then
    for lib in "${runtime_libs[@]}"; do
      target="$(find "${runtime_lib_dir}" -maxdepth 1 -name "${lib}.*" -print -quit)"
      if [[ -n "${target}" ]]; then
        replace_symlink "${target}" "${dst}/${lib}" || true
      fi
    done
  fi

  for lib in "${client_libs[@]}"; do
    target="${steam_root}/steamrtarm64/${lib}"
    if [[ -e "${target}" || -L "${target}" ]]; then
      replace_symlink "${target}" "${dst}/${lib}" || true
    fi
  done
}

validate_steam_arm64_runtime_links() {
  local missing steamui

  steamui="${steam_root}/steamrtarm64/steamui.so"
  [[ -f "${steamui}" ]] || return 0
  command -v ldd >/dev/null 2>&1 || return 0

  missing="$(
    LD_LIBRARY_PATH="${steam_root}/lib/aarch64-linux-gnu" \
      ldd "${steamui}" 2>/dev/null | awk '/not found/ {print}'
  )"
  [[ -z "${missing}" ]] || {
    printf 'Steam ARM64 runtime still has unresolved libraries:\n%s\n' "${missing}" >&2
    return 1
  }
}

link_first_existing() {
  local link fallback target

  link="$1"
  shift
  fallback="$1"

  for target in "$@"; do
    if [[ -e "${target}" || -L "${target}" ]]; then
      replace_symlink "${target}" "${link}"
      return 0
    fi
  done

  replace_symlink "${fallback}" "${link}"
}

ensure_steam_links() {
  mkdir -p "${HOME}/.steam" "${steam_root}/package"

  replace_symlink "${steam_root}" "${HOME}/.steam/steam" || true
  replace_symlink "${steam_root}" "${HOME}/.steam/root" || true
  link_first_existing "${HOME}/.steam/sdkarm64" "${steam_root}/steamrtarm64" "${steam_root}/linuxarm64"
  link_first_existing "${HOME}/.steam/steamrtarm64" "${steam_root}/steamrtarm64" "${steam_root}/linuxarm64"
}

resolve_fex_rootfs() {
  local rootfs_dir

  for rootfs_dir in "${FEX_ROOTFS_DIR:-}" "${HOME}/.fex-emu/RootFS" "${HOME}/.local/share/fex-emu/RootFS"; do
    [[ -n "${rootfs_dir}" ]] || continue
    if [[ -d "${rootfs_dir}/ArchLinux" ]]; then
      printf '%s\t%s\n' "${rootfs_dir}/ArchLinux" "ArchLinux"
      return 0
    fi
    if [[ -f "${rootfs_dir}/ArchLinux.sqsh" ]]; then
      printf '%s\t%s\n' "${rootfs_dir}/ArchLinux.sqsh" "ArchLinux.sqsh"
      return 0
    fi
  done

  return 1
}

install_rocknix_guest_freedreno() {
  local rootfs_name rootfs_path source_lib

  IFS=$'\t' read -r rootfs_path rootfs_name < <(resolve_fex_rootfs) || return 0
  source_lib="/usr/share/fex-emu/libvulkan_freedreno.so"
  [[ -d "${rootfs_path}/usr/lib" && -f "${source_lib}" ]] || return 0
  if file "${source_lib}" | grep -q 'x86-64'; then
    install -m 0755 "${source_lib}" "${rootfs_path}/usr/lib/libvulkan_freedreno.so"
  fi
}

install_steamos_compat_stubs() {
  mkdir -p "${support_bin_dir}"
  cat > "${support_bin_dir}/steamos-select-branch" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

branch_file="${STEAM_BASE_FOLDER:-${HOME}/.local/share/Steam}/package/beta"
branch="steamdeck_stable"
if [[ -r "${branch_file}" ]]; then
  branch="$(tr -d '\r\n' < "${branch_file}")"
fi

case "${1:-}" in
  --current|current|get-current|print-current|"")
    printf '%s\n' "${branch}"
    ;;
  --help|-h)
    echo "usage: steamos-select-branch [--current]"
    ;;
  *)
    printf '%s\n' "${branch}"
    ;;
esac
EOF
  cat > "${support_bin_dir}/steamos-update" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ -x /usr/bin/steamos-update ]]; then
  exec /usr/bin/steamos-update "$@"
fi

for arg in "$@"; do
  if [[ "${arg}" == "--supports-duplicate-detection" ]]; then
    echo "This helper supports the duplicate detection option." >&2
    exit 0
  fi
done

case "${1:-status}" in
  -h|--help|help)
    echo "usage: steamos-update [check|status|download|apply]"
    ;;
  check|status|list|list-updates)
    echo "No SteamOS system update is available on Thorch." >&2
    exit 7
    ;;
  download|update|apply|install|reboot|cleanup)
    echo "No SteamOS system update is available on Thorch." >&2
    exit 7
    ;;
  --beta|-d|--enable-duplicate-detection)
    echo "No SteamOS system update is available on Thorch." >&2
    exit 7
    ;;
  *)
    echo "SteamOS update command '${1:-status}' is not used on Thorch; no update is available." >&2
    exit 7
    ;;
esac
EOF

  cat > "${support_bin_dir}/jupiter-biosupdate" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ -x /usr/bin/jupiter-biosupdate ]]; then
  exec /usr/bin/jupiter-biosupdate "$@"
fi

case "${1:-check}" in
  -h|--help|help)
    echo "usage: jupiter-biosupdate [check|update|apply]"
    ;;
  check|status|list)
    echo "No Steam Deck firmware update is available on Thorch." >&2
    ;;
  update|apply|install)
    echo "Skipping Steam Deck firmware update on Thorch." >&2
    ;;
  *)
    echo "Steam Deck firmware command '${1:-check}' is not used on Thorch; treating as complete." >&2
    ;;
esac
EOF

  cat > "${support_bin_dir}/set-timezone" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ -x /usr/bin/set-timezone ]]; then
  exec /usr/bin/set-timezone "$@"
fi

echo "Timezone helper is not installed system-wide; leaving Thorch timezone unchanged."
EOF

  chmod 755 \
    "${support_bin_dir}/steamos-select-branch" \
    "${support_bin_dir}/steamos-update" \
    "${support_bin_dir}/jupiter-biosupdate" \
    "${support_bin_dir}/set-timezone"
}

install_steam_icon() {
  local icon target ext outdir tmp

  outdir="${HOME}/.local/share/icons/hicolor/256x256/apps"
  target="${outdir}/steam.png"

  [[ "${THORCH_STEAM_SKIP_ICON:-0}" == 1 ]] && return 0
  [[ -s "${target}" ]] && return 0

  tmp="$(mktemp -d)"
  if curl --connect-timeout 2 --max-time 8 -fsSL -o "${tmp}/steam.deb" "https://repo.steampowered.com/steam/archive/precise/steam_latest.deb" &&
      (cd "${tmp}" && ar x steam.deb data.tar.xz) &&
      tar -xOf "${tmp}/data.tar.xz" ./usr/share/icons/hicolor/256x256/apps/steam.png > "${tmp}/steam.png"; then
    install -d "${outdir}"
    install -m 0644 "${tmp}/steam.png" "${target}"
    rm -rf "${tmp}"
    command -v gtk-update-icon-cache >/dev/null 2>&1 &&
      gtk-update-icon-cache -q "${HOME}/.local/share/icons/hicolor" 2>/dev/null || true
    return 0
  fi
  rm -rf "${tmp}"

  icon="$(find "${steam_root}" -type f \( \
      -iname 'steam.svg' -o \
      -iname 'steam.png' -o \
      -iname 'steam_tray*.png' -o \
      -iname 'icon_steam.tga' \
    \) -print 2>/dev/null | sort | head -n1)"

  [[ -n "${icon}" ]] || return 0

  ext="${icon##*.}"
  case "${ext,,}" in
    svg)
      outdir="${HOME}/.local/share/icons/hicolor/scalable/apps"
      target="${outdir}/steam.svg"
      ;;
    png)
      outdir="${HOME}/.local/share/icons/hicolor/256x256/apps"
      target="${outdir}/steam.png"
      ;;
    tga)
      outdir="${HOME}/.local/share/icons/hicolor/256x256/apps"
      target="${outdir}/steam.png"
      ;;
    *)
      return 0
      ;;
  esac

  install -d "${outdir}"
  if [[ "${ext,,}" == "tga" ]]; then
    python - "${icon}" "${target}" <<'PY'
import struct
import sys
import zlib

src, dst = sys.argv[1], sys.argv[2]
data = open(src, "rb").read()
if len(data) < 18:
    raise SystemExit("TGA header is too short")

id_len, color_map_type, image_type = data[0], data[1], data[2]
width, height, bpp, descriptor = struct.unpack_from("<HHBB", data, 12)
if color_map_type or image_type != 2 or bpp not in (24, 32) or not width or not height:
    raise SystemExit("Unsupported Steam TGA format")

pixel_size = bpp // 8
offset = 18 + id_len
pixels = data[offset:offset + width * height * pixel_size]
if len(pixels) != width * height * pixel_size:
    raise SystemExit("TGA pixel data is truncated")

top_origin = bool(descriptor & 0x20)
rows = []
for y in range(height):
    src_y = y if top_origin else height - 1 - y
    start = src_y * width * pixel_size
    row = bytearray()
    for x in range(width):
        px = pixels[start + x * pixel_size:start + (x + 1) * pixel_size]
        b, g, r = px[0], px[1], px[2]
        a = px[3] if pixel_size == 4 else 255
        row.extend((r, g, b, a))
    rows.append(b"\x00" + bytes(row))

def chunk(kind, payload):
    return struct.pack(">I", len(payload)) + kind + payload + struct.pack(">I", zlib.crc32(kind + payload) & 0xffffffff)

png = b"\x89PNG\r\n\x1a\n"
png += chunk(b"IHDR", struct.pack(">IIBBBBB", width, height, 8, 6, 0, 0, 0))
png += chunk(b"IDAT", zlib.compress(b"".join(rows), 9))
png += chunk(b"IEND", b"")
open(dst, "wb").write(png)
PY
  else
    install -m 0644 "${icon}" "${target}"
  fi
  command -v gtk-update-icon-cache >/dev/null 2>&1 &&
    gtk-update-icon-cache -q "${HOME}/.local/share/icons/hicolor" 2>/dev/null || true
}

if [[ "${1:-}" == "--repair-runtime-links" ]]; then
  ensure_steam_links
  install_steam_registry
  repair_steam_arm64_runtime_links
  validate_steam_arm64_runtime_links
  exit 0
fi

if [[ ! -d "${steam_root}/steam-runtime-steamrt-arm64" ]]; then
  wget "${wget_retry[@]}" -O "${steam_root}/steam-runtime-steamrt-arm64.tar.xz" \
    "https://repo.steampowered.com/steamrt3c/images/latest-public-beta/steam-runtime-steamrt-arm64.tar.xz"
  tar xvf "${steam_root}/steam-runtime-steamrt-arm64.tar.xz" -C "${steam_root}"
  rm -f "${steam_root}/steam-runtime-steamrt-arm64.tar.xz"
fi

repair_steam_arm64_runtime_links

if [[ ! -d "${steam_root}/steamrtarm64" ]]; then
  manifest_url="${THORCH_STEAM_MANIFEST_URL:-https://client-update.fastly.steamstatic.com/steam_client_${steam_branch}_linuxarm64}"
  manifest="$(curl -fsSL "${manifest_url}" | strings)"
  target_file="$(printf '%s\n' "${manifest}" | grep -Eo 'bins_linuxarm64_linuxarm64\.zip\.[^"]+' | grep -v '\.vz\.' | head -n1)"
  [[ -n "${target_file}" ]] || { echo "Could not find ARM64 Steam zip in Valve manifest" >&2; exit 1; }
  wget "${wget_retry[@]}" -O "${steam_root}/linuxarm64.zip" "https://client-update.steamstatic.com/${target_file}"
  unzip -o "${steam_root}/linuxarm64.zip" -d "${steam_root}"
  rm -f "${steam_root}/linuxarm64.zip"
  chmod +x "${steam_root}/steamrtarm64/steam"
fi

repair_steam_arm64_runtime_links
validate_steam_arm64_runtime_links
ensure_steam_links
install_steam_registry
mkdir -p "${steam_root}/steamrtarm64/bin"
if [[ -x "${steam_root}/linuxarm64/steam-launch-wrapper" ]]; then
  replace_symlink ../linuxarm64/steam-launch-wrapper "${steam_root}/steamrtarm64/steam-launch-wrapper" || true
fi
if [[ -x "${HOME}/.local/bin/thorch-repair-steam-arm64" ]]; then
  "${HOME}/.local/bin/thorch-repair-steam-arm64" || true
elif command -v thorch-repair-steam-arm64 >/dev/null 2>&1; then
  thorch-repair-steam-arm64 || true
fi
replace_symlink ../vgui2_s.so "${steam_root}/steamrtarm64/bin/vgui2_s.dll" || true
replace_symlink ../filesystem_stdio.so "${steam_root}/steamrtarm64/bin/FileSystem_Steam.dll" || true
install_steam_icon
install_steamos_compat_stubs
install_rocknix_guest_freedreno
echo "Steam ARM64 setup complete."
