#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: thorch-steamos-mode start|stop|restart|status|is-running|enable|disable|move-windows-bottom|move-steam-top|move-active-top|move-active-bottom

SteamOS mode keeps Plasma/KWin as the real two-screen session, then runs Steam
inside nested gamescope on the configured Steam output.
EOF
  exit 2
}

cmd="${1:-start}"
case "${cmd}" in
  start|stop|restart|status|is-running|enable|disable|run|move-windows-bottom|move-steam-top|move-active-top|move-active-bottom) ;;
  *) usage ;;
esac

uid="$(id -u)"
steam_output="${THORCH_STEAMOS_STEAM_OUTPUT:-DSI-2}"
control_output="${THORCH_STEAMOS_CONTROL_OUTPUT:-DSI-1}"
width="${THORCH_STEAMOS_WIDTH:-1920}"
height="${THORCH_STEAMOS_HEIGHT:-1080}"
refresh="${THORCH_STEAMOS_REFRESH:-120}"
backend="${THORCH_STEAMOS_GAMESCOPE_BACKEND:-nested}"
steam_mode="${THORCH_STEAMOS_STEAM_MODE:-deck}"
steam_branch="${THORCH_STEAMOS_STEAM_BRANCH:-publicbeta}"
state_home="${XDG_STATE_HOME:-${HOME}/.local/state}"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${uid}}"
log_dir="${state_home}/thorch"
log_file="${log_dir}/steamos-mode.log"
pid_file="${runtime_dir}/thorch-steamos-mode.pid"
autostart_dir="${HOME}/.config/autostart"
autostart_file="${autostart_dir}/thorch-steamos-mode.desktop"
kwin_script="${runtime_dir}/thorch-steamos-mode-kwin.js"
launcher="${THORCH_STEAMOS_LAUNCHER:-${HOME}/.local/bin/thorch-start-steam-arm64}"
self_command="${THORCH_STEAMOS_SELF:-/usr/bin/thorch-steamos-mode}"

detect_display() {
  local sock last

  if [[ -n "${DISPLAY:-}" ]]; then
    return 0
  fi

  last=""
  for sock in /tmp/.X11-unix/X*; do
    [[ -S "${sock}" ]] || continue
    last=":${sock##*/X}"
  done
  export DISPLAY="${last:-:0}"
}

detect_xauthority() {
  local auth

  if [[ -n "${XAUTHORITY:-}" && -f "${XAUTHORITY}" ]]; then
    return 0
  fi

  auth="$(find "${runtime_dir}" -maxdepth 1 -type f -name 'xauth_*' -print -quit 2>/dev/null || true)"
  if [[ -n "${auth}" ]]; then
    export XAUTHORITY="${auth}"
  fi
}

ensure_session_env() {
  export XDG_RUNTIME_DIR="${runtime_dir}"
  export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${runtime_dir}/bus}"
  if [[ -z "${WAYLAND_DISPLAY:-}" && -S "${runtime_dir}/wayland-0" ]]; then
    export WAYLAND_DISPLAY=wayland-0
  fi
  detect_display
  detect_xauthority
  export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
  export LANG="${LANG:-C.UTF-8}"
  export LC_ALL="${LC_ALL:-C.UTF-8}"
}

json_string() {
  python -c 'import json, sys; print(json.dumps(sys.argv[1]))' "$1"
}

load_kwin_mode_script() {
  local output_json

  command -v qdbus6 >/dev/null 2>&1 || return 0
  [[ -S "${runtime_dir}/bus" ]] || return 0

  output_json="$(json_string "${steam_output}")"
  install -d -m 0700 "${runtime_dir}"
  cat > "${kwin_script}" <<EOF
"use strict";

const steamOutputName = ${output_json};

function textValue(value) {
    if (value === undefined || value === null) {
        return "";
    }
    try {
        return value.toString();
    } catch (e) {
        return "";
    }
}

function outputName(output) {
    return textValue(output && output.name);
}

function steamOutput() {
    const outputLists = [
        workspace.screens || [],
        workspace.screenOrder || []
    ];
    for (const screens of outputLists) {
        for (const output of screens) {
            if (outputName(output) === steamOutputName) {
                return output;
            }
        }
    }
    return workspace.activeScreen;
}

function isSteamModeWindow(window) {
    if (!window || !(window.normalWindow || window.dialog)) {
        return false;
    }

    // Check resource/class identifiers for "steam" – but NOT the caption/title,
    // otherwise any window whose title happens to contain "steam" gets captured.
    const identity = [
        window.resourceClass,
        window.resourceName,
        window.windowClass,
        window.desktopFileName,
        window.windowRole
    ].map(textValue).join(" ").toLowerCase();

    if (identity.indexOf("steam") !== -1) {
        return true;
    }

    // Gamescope is the nested compositor, so matching it in the full haystack
    // (including caption) is fine – only gamescope windows will have that name.
    const full = (identity + " " + [
        window.caption,
        window.captionNormal
    ].map(textValue).join(" ")).toLowerCase();

    return full.indexOf("gamescope") !== -1;
}

function isThorchActionDrawer(window) {
    if (!window) {
        return false;
    }
    const caption = textValue(window.caption || window.captionNormal);
    const resource = textValue(window.resourceClass || window.resourceName || window.windowClass).toLowerCase();
    return caption === "Thorch Action Drawer" &&
           resource.indexOf("plasmashell") !== -1;
}

function applyThorchActionDrawer(window) {
    if (!isThorchActionDrawer(window)) {
        return;
    }
    try {
        window.skipTaskbar = true;
        window.skipSwitcher = true;
    } catch (e) {
    }
}

function applySteamMode(window) {
    if (!isSteamModeWindow(window)) {
        return;
    }

    const output = steamOutput();
    if (!output) {
        return;
    }

    try {
        window.fullScreen = false;
    } catch (e) {
    }
    try {
        workspace.sendClientToScreen(window, output);
    } catch (e) {
        console.info("thorch-steamos-mode: could not send window to output: " + e);
    }
    try {
        window.noBorder = true;
    } catch (e) {
        console.info("thorch-steamos-mode: could not set noBorder: " + e);
    }
    try {
        window.fullScreen = true;
    } catch (e) {
        console.info("thorch-steamos-mode: could not set fullscreen: " + e);
    }
    try {
        window.skipTaskbar = false;
        window.skipSwitcher = false;
    } catch (e) {
    }
}

function wireWindow(window) {
    applyThorchActionDrawer(window);
    applySteamMode(window);
    try {
        window.captionChanged.connect(() => applyThorchActionDrawer(window));
        window.captionChanged.connect(() => applySteamMode(window));
        window.outputChanged.connect(() => applySteamMode(window));
    } catch (e) {
    }
}

function applyAll() {
    workspace.windowList().forEach(wireWindow);
}

workspace.windowAdded.connect(wireWindow);
workspace.screensChanged.connect(applyAll);
workspace.screenOrderChanged.connect(applyAll);
applyAll();
EOF

  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.unloadScript thorch-steamos-mode >/dev/null 2>&1 || true
  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.loadScript "${kwin_script}" thorch-steamos-mode >/dev/null 2>&1 || true
  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.start >/dev/null 2>&1 || true
}

unload_kwin_mode_script() {
  command -v qdbus6 >/dev/null 2>&1 || return 0
  [[ -S "${runtime_dir}/bus" ]] || return 0
  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.unloadScript thorch-steamos-mode >/dev/null 2>&1 || true
}

ensure_launcher() {
  if command -v thorch-install-fex >/dev/null 2>&1; then
    thorch-install-fex
  fi

  if [[ -x "${launcher}" ]]; then
    return 0
  fi

  if command -v thorch-install-steam-arm64 >/dev/null 2>&1; then
    thorch-install-steam-arm64 --yes
  fi

  if [[ ! -x "${launcher}" ]]; then
    echo "Steam ARM64 launcher is missing. Run thorch-install-gaming-stack first." >&2
    exit 1
  fi
}

running() {
  supervisor_running ||
  pgrep -u "${uid}" -x gamescope-wl >/dev/null 2>&1 ||
    pgrep -u "${uid}" -x gamescope >/dev/null 2>&1 ||
    pgrep -u "${uid}" -x steam >/dev/null 2>&1
}

supervisor_running() {
  local args pid

  [[ -r "${pid_file}" ]] || return 1
  pid="$(cat "${pid_file}" 2>/dev/null || true)"
  [[ -n "${pid}" ]] || return 1
  kill -0 "${pid}" >/dev/null 2>&1 || return 1
  args="$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true)"
  [[ "${args}" == *"thorch-steamos-mode run"* ]]
}

run_mode() {
  local attempt elapsed rc started_at

  ensure_session_env
  install -d -m 0755 "${log_dir}"
  echo "$$" > "${pid_file}"
  trap 'rm -f "${pid_file}"' EXIT

  for attempt in 1 2 3; do
    echo "Starting SteamOS mode attempt ${attempt} on ${steam_output}..."
    started_at="$(date +%s)"
    if env \
      XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" \
      DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS}" \
      WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
      DISPLAY="${DISPLAY}" \
      XAUTHORITY="${XAUTHORITY:-}" \
      XDG_SESSION_TYPE="${XDG_SESSION_TYPE}" \
      LANG="${LANG}" \
      LC_ALL="${LC_ALL}" \
      THORCH_STEAM_MODE="${steam_mode}" \
      THORCH_STEAM_USE_GAMESCOPE=1 \
      THORCH_STEAM_GAMESCOPE_WIDTH="${width}" \
      THORCH_STEAM_GAMESCOPE_HEIGHT="${height}" \
      THORCH_STEAM_GAMESCOPE_REFRESH="${refresh}" \
      THORCH_STEAM_GAMESCOPE_BACKEND="${backend}" \
      THORCH_STEAM_BRANCH="${steam_branch}" \
      THORCH_STEAM_MANGOHUD="${THORCH_STEAM_MANGOHUD:-auto}" \
      THORCH_STEAM_SKIP_BOOTSTRAP="${THORCH_STEAM_SKIP_BOOTSTRAP:-1}" \
      THORCH_STEAM_SKIP_ICON=1 \
      "${launcher}"; then
      rc=0
    else
      rc=$?
    fi
    elapsed="$(( $(date +%s) - started_at ))"
    echo "SteamOS mode attempt ${attempt} exited with ${rc}."
    sleep 3

    if [[ "${attempt}" -lt 3 && "${elapsed}" -lt 120 ]]; then
      echo "Relaunching SteamOS mode after Steam updater/client handoff..."
    else
      break
    fi
  done

  return "${rc:-0}"
}

start_mode() {
  local launch_pid launch_status=0 tick wait_ticks
  ensure_session_env
  install -d -m 0755 "${log_dir}"

  if running; then
    echo "SteamOS mode already appears to be running."
    return 0
  fi

  ensure_launcher
  load_kwin_mode_script

  setsid env \
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" \
    DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS}" \
    WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
    DISPLAY="${DISPLAY}" \
    XAUTHORITY="${XAUTHORITY:-}" \
    XDG_SESSION_TYPE="${XDG_SESSION_TYPE}" \
    LANG="${LANG}" \
    LC_ALL="${LC_ALL}" \
    THORCH_STEAMOS_STEAM_OUTPUT="${steam_output}" \
    THORCH_STEAMOS_WIDTH="${width}" \
    THORCH_STEAMOS_HEIGHT="${height}" \
    THORCH_STEAMOS_REFRESH="${refresh}" \
    THORCH_STEAMOS_GAMESCOPE_BACKEND="${backend}" \
    THORCH_STEAMOS_STEAM_MODE="${steam_mode}" \
    THORCH_STEAMOS_STEAM_BRANCH="${steam_branch}" \
    THORCH_STEAM_MANGOHUD="${THORCH_STEAM_MANGOHUD:-auto}" \
    THORCH_STEAM_SKIP_BOOTSTRAP="${THORCH_STEAM_SKIP_BOOTSTRAP:-1}" \
    THORCH_STEAM_SDL_VIDEODRIVER="${THORCH_STEAM_SDL_VIDEODRIVER:-${SDL_VIDEODRIVER:-x11}}" \
    "${self_command}" run >>"${log_file}" 2>&1 < /dev/null &
  launch_pid="$!"
  echo "${launch_pid}" > "${pid_file}"

  wait_ticks="${THORCH_STEAMOS_STARTUP_WAIT_TICKS:-30}"
  for ((tick = 0; tick < wait_ticks; ++tick)); do
    if ! kill -0 "${launch_pid}" >/dev/null 2>&1; then
      wait "${launch_pid}" || launch_status=$?
      rm -f "${pid_file}"
      if [[ "${launch_status}" -eq 0 ]]; then
        launch_status=1
      fi
      echo "SteamOS mode failed to start (exit ${launch_status:-0}); log: ${log_file}" >&2
      return "${launch_status}"
    fi
    sleep 0.1
  done

  echo "Started SteamOS mode on ${steam_output}; log: ${log_file}"
}

stop_mode() {
  ensure_session_env

  if supervisor_running; then
    kill "$(cat "${pid_file}")" >/dev/null 2>&1 || true
  fi
  pkill -TERM -u "${uid}" -x steam >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -x steamwebhelper >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -x gamescope-wl >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -x gamescope >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -x gamescopereaper >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -f '[t]horch-start-steam-arm64' >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -f '[s]team-runtime-launcher-service --alongside-steam' >/dev/null 2>&1 || true
  pkill -TERM -u "${uid}" -f '/usr/bin/FEX .*/\.local/share/Steam/steamapps/common/' >/dev/null 2>&1 || true
  sleep 2
  pkill -KILL -u "${uid}" -x steam >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -x steamwebhelper >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -x gamescope-wl >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -x gamescope >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -x gamescopereaper >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -f '[t]horch-start-steam-arm64' >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -f '[s]team-runtime-launcher-service --alongside-steam' >/dev/null 2>&1 || true
  pkill -KILL -u "${uid}" -f '/usr/bin/FEX .*/\.local/share/Steam/steamapps/common/' >/dev/null 2>&1 || true
  rm -f "${pid_file}"
  unload_kwin_mode_script
  echo "Stopped SteamOS mode."
}

run_window_move_script() {
  local script_id target_output_name move_mode message
  local move_mode_json move_script target_output_json

  script_id="$1"
  target_output_name="$2"
  move_mode="$3"
  message="$4"

  ensure_session_env
  command -v qdbus6 >/dev/null 2>&1 || {
    echo "qdbus6 is missing; cannot ask KWin to move windows." >&2
    return 1
  }
  [[ -S "${runtime_dir}/bus" ]] || {
    echo "KWin session bus is not available." >&2
    return 1
  }

  target_output_json="$(json_string "${target_output_name}")"
  move_mode_json="$(json_string "${move_mode}")"
  move_script="${runtime_dir}/${script_id}-kwin.js"
  install -d -m 0700 "${runtime_dir}"
  cat > "${move_script}" <<EOF
"use strict";

const targetOutputName = ${target_output_json};
const moveMode = ${move_mode_json};

function textValue(value) {
    if (value === undefined || value === null) {
        return "";
    }
    try {
        return value.toString();
    } catch (e) {
        return "";
    }
}

function outputName(output) {
    return textValue(output && output.name);
}

function targetOutput() {
    const outputLists = [
        workspace.screens || [],
        workspace.screenOrder || []
    ];
    for (const screens of outputLists) {
        for (const output of screens) {
            if (outputName(output) === targetOutputName) {
                return output;
            }
        }
    }
    return null;
}

function isSteamModeWindow(window) {
    if (!window || !(window.normalWindow || window.dialog)) {
        return false;
    }

    const identity = [
        window.resourceClass,
        window.resourceName,
        window.windowClass,
        window.desktopFileName,
        window.windowRole
    ].map(textValue).join(" ").toLowerCase();

    if (identity.indexOf("steam") !== -1) {
        return true;
    }

    const full = (identity + " " + [
        window.caption,
        window.captionNormal
    ].map(textValue).join(" ")).toLowerCase();

    return full.indexOf("gamescope") !== -1;
}

function isThorchActionDrawer(window) {
    if (!window) {
        return false;
    }
    const caption = textValue(window.caption || window.captionNormal);
    const resource = textValue(window.resourceClass || window.resourceName || window.windowClass).toLowerCase();
    return caption === "Thorch Action Drawer" &&
           resource.indexOf("plasmashell") !== -1;
}

function isMovableWindow(window) {
    return window &&
           (window.normalWindow || window.dialog) &&
           !isThorchActionDrawer(window);
}

function shouldMoveWindow(window) {
    if (!isMovableWindow(window)) {
        return false;
    }
    if (moveMode === "nonSteam") {
        return !isSteamModeWindow(window);
    }
    if (moveMode === "steam") {
        return isSteamModeWindow(window);
    }
    return false;
}

function activeWindow() {
    return workspace.activeWindow || workspace.activeClient || null;
}

function windowStack() {
    try {
        if (workspace.stackingOrder && workspace.stackingOrder.length > 0) {
            return workspace.stackingOrder;
        }
    } catch (e) {
    }
    return workspace.windowList();
}

function activeMovableWindow() {
    const active = activeWindow();
    if (isMovableWindow(active)) {
        return active;
    }

    const windows = windowStack();
    for (let i = windows.length - 1; i >= 0; --i) {
        if (isMovableWindow(windows[i])) {
            return windows[i];
        }
    }
    return null;
}

function moveWindow(window, output) {
    if (!isMovableWindow(window)) {
        return;
    }

    const wasFullScreen = !!window.fullScreen;
    try {
        window.fullScreen = false;
    } catch (e) {
    }
    try {
        workspace.sendClientToScreen(window, output);
    } catch (e) {
        console.info("thorch-steamos-mode: could not move window to target output: " + e);
    }
    if (moveMode === "steam" && isSteamModeWindow(window)) {
        try {
            window.noBorder = true;
        } catch (e) {
        }
        try {
            window.fullScreen = true;
        } catch (e) {
        }
        try {
            window.skipTaskbar = false;
            window.skipSwitcher = false;
        } catch (e) {
        }
    } else {
        try {
            window.fullScreen = wasFullScreen;
        } catch (e) {
        }
    }
}

const output = targetOutput();
if (!output) {
    console.info("thorch-steamos-mode: target output not found: " + targetOutputName);
} else if (moveMode === "active") {
    const window = activeMovableWindow();
    if (window) {
        moveWindow(window, output);
    } else {
        console.info("thorch-steamos-mode: no active movable window found");
    }
} else {
    workspace.windowList()
        .filter(shouldMoveWindow)
        .forEach(window => moveWindow(window, output));
}
EOF

  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.unloadScript "${script_id}" >/dev/null 2>&1 || true
  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.loadScript "${move_script}" "${script_id}" >/dev/null 2>&1 || true
  timeout 5s qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.start >/dev/null 2>&1 || true
  echo "${message}"
}

move_windows_bottom() {
  run_window_move_script \
    "thorch-move-windows-bottom" \
    "${control_output}" \
    "nonSteam" \
    "Moved non-Steam windows to ${control_output}."
}

move_steam_top() {
  run_window_move_script \
    "thorch-move-steam-top" \
    "${steam_output}" \
    "steam" \
    "Moved Steam windows to ${steam_output}."
}

move_active_top() {
  run_window_move_script \
    "thorch-move-active-top" \
    "${steam_output}" \
    "active" \
    "Moved the active window to ${steam_output}."
}

move_active_bottom() {
  run_window_move_script \
    "thorch-move-active-bottom" \
    "${control_output}" \
    "active" \
    "Moved the active window to ${control_output}."
}

status_mode() {
  if running; then
    echo "SteamOS mode is running."
    ps -u "${uid}" -o pid=,comm=,args= |
      awk '$2 ~ /^(gamescope|gamescope-wl|gamescopereaper|steam|steamwebhelper|steam-runtime-l)$/ {print}' || true
  else
    echo "SteamOS mode is not running."
  fi

  if [[ -f "${autostart_file}" ]]; then
    echo "Autostart is enabled."
  else
    echo "Autostart is disabled."
  fi
}

is_running_mode() {
  if running; then
    echo "running"
  else
    echo "stopped"
  fi
}

enable_autostart() {
  install -d -m 0755 "${autostart_dir}"
  cat > "${autostart_file}" <<'EOF'
[Desktop Entry]
Type=Application
Name=Thorch SteamOS Mode
Exec=/usr/bin/thorch-steamos-mode start
OnlyShowIn=KDE;
Terminal=false
X-KDE-autostart-phase=2
EOF
  echo "Enabled SteamOS mode autostart."
}

disable_autostart() {
  rm -f "${autostart_file}"
  echo "Disabled SteamOS mode autostart."
}

case "${cmd}" in
  start)
    start_mode
    ;;
  stop)
    stop_mode
    ;;
  restart)
    stop_mode
    start_mode
    ;;
  status)
    status_mode
    ;;
  is-running)
    is_running_mode
    ;;
  run)
    run_mode
    ;;
  enable)
    enable_autostart
    ;;
  disable)
    disable_autostart
    ;;
  move-windows-bottom)
    move_windows_bottom
    ;;
  move-steam-top)
    move_steam_top
    ;;
  move-active-top)
    move_active_top
    ;;
  move-active-bottom)
    move_active_bottom
    ;;
esac
