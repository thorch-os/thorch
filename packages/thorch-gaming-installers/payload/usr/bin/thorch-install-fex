#!/usr/bin/env bash
set -euo pipefail

if ! command -v FEX >/dev/null 2>&1; then
  cat >&2 <<'EOF'
FEX is required but is not installed.

Install the Thorch package first:
  pacman -S --needed --noconfirm thorch-fex-bin
EOF
  exit 1
fi

restart_binfmt() {
  if [[ "${EUID}" -eq 0 ]]; then
    systemctl restart systemd-binfmt.service 2>/dev/null || true
  elif command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
    sudo systemctl restart systemd-binfmt.service 2>/dev/null || true
  fi
}

resolve_fex_rootfs() {
  local rootfs_dir

  for rootfs_dir in "${FEX_ROOTFS_DIR:-}" "${HOME}/.fex-emu/RootFS" "${HOME}/.local/share/fex-emu/RootFS"; do
    [[ -n "${rootfs_dir}" ]] || continue
    if [[ -d "${rootfs_dir}/ArchLinux" ]]; then
      printf '%s\t%s\n' "${rootfs_dir}/ArchLinux" "ArchLinux"
      return 0
    fi
    if [[ -f "${rootfs_dir}/ArchLinux.sqsh" ]]; then
      printf '%s\t%s\n' "${rootfs_dir}/ArchLinux.sqsh" "ArchLinux.sqsh"
      return 0
    fi
  done

  return 1
}

ensure_canonical_fex_rootfs() {
  local rootfs_name="$1" rootfs_path="$2" target

  [[ -n "${rootfs_name}" && -n "${rootfs_path}" ]] || return 0
  mkdir -p "${HOME}/.fex-emu/RootFS"
  target="${HOME}/.fex-emu/RootFS/${rootfs_name}"

  if [[ "${rootfs_path}" == "${target}" ]]; then
    return 0
  fi

  if [[ -L "${target}" || -f "${target}" ]]; then
    rm -f "${target}"
  elif [[ -d "${target}" ]]; then
    return 0
  fi

  ln -sfnT "${rootfs_path}" "${target}"
}

write_fex_config_defaults() {
  local config_file="$1" rootfs_path="$2" template_override

  template_override="${THORCH_FEX_CONFIG_TEMPLATE:-}"
  python3 - "${config_file}" "${rootfs_path}" "${template_override}" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
rootfs_path = str(pathlib.Path(sys.argv[2]).resolve(strict=True))
new_config = not path.exists()
templates = tuple(filter(None, (
    pathlib.Path(sys.argv[3]) if sys.argv[3] else None,
    pathlib.Path("/usr/share/fex-emu/Config.json"),
    pathlib.Path("/usr/config/fex-emu/Config.json"),
    pathlib.Path("/usr/share/thorch/fex-emu/Config.json"),
)))

if path.exists():
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Refusing to overwrite invalid user FEX config {path}: {exc}")
else:
    template = next((candidate for candidate in templates if candidate.exists()), None)
    try:
        data = json.loads(template.read_text(encoding="utf-8")) if template else {}
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Invalid packaged FEX config {template}: {exc}")

if not isinstance(data, dict):
    raise SystemExit(f"Invalid user FEX config {path}: top level must be an object")
config = data.setdefault("Config", {})
if not isinstance(config, dict):
    raise SystemExit(f"Invalid user FEX config {path}: Config must be an object")

# Migrate only the old Thorch-managed relative selections. Preserve an explicit
# user-selected rootfs and every unrelated FEX tuning choice.
if config.get("RootFS") in (None, "", "ArchLinux", "ArchLinux.sqsh"):
    config["RootFS"] = rootfs_path

defaults = {
    "ServerSocketPath": "",
    "ThunkHostLibs": "/usr/lib/fex-emu/HostThunks",
    "ThunkGuestLibs": "/usr/share/fex-emu/GuestThunks",
    "TSOEnabled": "1",
    "Multiblock": "1",
    "X87ReducedPrecision": "1",
    "SilentLog": "1",
    "OutputLog": "server",
}
for key, value in defaults.items():
    config.setdefault(key, value)

thunk_defaults = {
    "GL": 1,
    "Vulkan": 1,
    "drm": 1,
    "asound": 1,
    "WaylandClient": 1,
    "fex_thunk_test": 0,
}
thunks = data.setdefault("ThunksDB", {})
if not isinstance(thunks, dict):
    raise SystemExit(f"Invalid user FEX config {path}: ThunksDB must be an object")
if new_config:
    thunks.update(thunk_defaults)
else:
    for key, value in thunk_defaults.items():
        thunks.setdefault(key, value)

path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
PY
}

unpack_fex_rootfs_for_freedreno() {
  local rootfs_dir="$1" rootfs_file="$2" rootfs_tree="$3" tmp_tree

  [[ -f "${rootfs_file}" ]] || return 0
  [[ ! -d "${rootfs_tree}/usr/lib" ]] || return 0
  command -v unsquashfs >/dev/null 2>&1 || {
    echo "unsquashfs is required to unpack the FEX Arch rootfs." >&2
    exit 1
  }

  # The Steam pressure-vessel path expects a normal unpacked x86_64 guest rootfs.
  # Keep it unpacked so we can repair accidental host-library contamination.
  tmp_tree="$(mktemp -d "${rootfs_dir}/ArchLinux.tmp.XXXXXX")"
  if unsquashfs -no-progress -f -d "${tmp_tree}" "${rootfs_file}" >/dev/null; then
    rm -rf "${rootfs_tree}"
    mv "${tmp_tree}" "${rootfs_tree}"
  else
    rm -rf "${tmp_tree}"
    echo "Failed to unpack ${rootfs_file}" >&2
    exit 1
  fi
}

rootfs_tree_looks_valid() {
  local rootfs_tree="$1"

  [[ -d "${rootfs_tree}/usr/lib" ]] || return 1
  [[ -e "${rootfs_tree}/bin/sh" || -e "${rootfs_tree}/usr/bin/sh" ||
      -e "${rootfs_tree}/bin/bash" || -e "${rootfs_tree}/usr/bin/bash" ]] || return 1
}

rootfs_sqsh_looks_valid() {
  local rootfs_file="$1"

  [[ -s "${rootfs_file}" ]] || return 1
  command -v unsquashfs >/dev/null 2>&1 || {
    echo "unsquashfs is required to validate the FEX Arch rootfs." >&2
    exit 1
  }
  unsquashfs -s "${rootfs_file}" >/dev/null 2>&1
}

quarantine_bad_rootfs() {
  local path="$1" reason="$2" quarantine

  [[ -e "${path}" || -L "${path}" ]] || return 0
  quarantine="${path}.invalid.$(date +%Y%m%d%H%M%S).$$"
  echo "Existing FEX rootfs ${path} is ${reason}; moving it to ${quarantine}."
  mv "${path}" "${quarantine}"
}

repair_rootfs_dir_before_fetch() {
  local rootfs_dir="$1" rootfs_file rootfs_tree

  rootfs_file="${rootfs_dir}/ArchLinux.sqsh"
  rootfs_tree="${rootfs_dir}/ArchLinux"

  if [[ -f "${rootfs_file}" ]] && ! rootfs_sqsh_looks_valid "${rootfs_file}"; then
    quarantine_bad_rootfs "${rootfs_file}" "not a readable squashfs image"
  fi

  if [[ -d "${rootfs_tree}" ]] && ! rootfs_tree_looks_valid "${rootfs_tree}"; then
    quarantine_bad_rootfs "${rootfs_tree}" "incomplete"
  fi
}

rootfs_dir_has_valid_candidate() {
  local rootfs_dir="$1"

  [[ -d "${rootfs_dir}/ArchLinux" ]] && rootfs_tree_looks_valid "${rootfs_dir}/ArchLinux" && return 0
  [[ -f "${rootfs_dir}/ArchLinux.sqsh" ]] && rootfs_sqsh_looks_valid "${rootfs_dir}/ArchLinux.sqsh" && return 0
  return 1
}

restore_guest_freedreno_from_rootfs() {
  local rootfs_dir="$1" rootfs_file="$2" rootfs_tree="$3" guest_lib tmp_tree

  guest_lib="${rootfs_tree}/usr/lib/libvulkan_freedreno.so"
  [[ -d "${rootfs_tree}/usr/lib" && -f "${rootfs_file}" ]] || return 0
  if [[ -f "${guest_lib}" ]] && file "${guest_lib}" | grep -q 'x86-64'; then
    return 0
  fi

  command -v unsquashfs >/dev/null 2>&1 || {
    echo "unsquashfs is required to restore the FEX guest Freedreno library." >&2
    exit 1
  }

  echo "Restoring x86_64 guest Freedreno library from ${rootfs_file}."
  tmp_tree="$(mktemp -d "${rootfs_dir}/freedreno-guest.XXXXXX")"
  if unsquashfs -no-progress -f -d "${tmp_tree}" "${rootfs_file}" usr/lib/libvulkan_freedreno.so >/dev/null &&
      [[ -f "${tmp_tree}/usr/lib/libvulkan_freedreno.so" ]]; then
    install -m 0755 "${tmp_tree}/usr/lib/libvulkan_freedreno.so" "${guest_lib}"
    rm -rf "${tmp_tree}"
  else
    rm -rf "${tmp_tree}"
    echo "Failed to restore x86_64 guest Freedreno from ${rootfs_file}" >&2
    exit 1
  fi
}

install_rocknix_guest_freedreno() {
  local rootfs_dir="$1" rootfs_file="$2" rootfs_tree="$3" guest_lib source_lib

  guest_lib="${rootfs_tree}/usr/lib/libvulkan_freedreno.so"
  source_lib="/usr/share/fex-emu/libvulkan_freedreno.so"
  [[ -d "${rootfs_tree}/usr/lib" ]] || return 0

  if [[ -f "${source_lib}" ]] && file "${source_lib}" | grep -q 'x86-64'; then
    install -m 0755 "${source_lib}" "${guest_lib}"
    return 0
  fi

  restore_guest_freedreno_from_rootfs "${rootfs_dir}" "${rootfs_file}" "${rootfs_tree}"
}

restart_binfmt

legacy_config_dst="${HOME}/.fex-emu"
xdg_config_dst="${XDG_CONFIG_HOME:-${HOME}/.config}/fex-emu"
if [[ ! -e "${legacy_config_dst}/Config.json" && -e "${xdg_config_dst}/Config.json" ]]; then
  mkdir -p "${legacy_config_dst}"
  cp -a "${xdg_config_dst}/." "${legacy_config_dst}/"
fi

if command -v FEXRootFSFetcher >/dev/null 2>&1; then
  rootfs_dir="${FEX_ROOTFS_DIR:-${HOME}/.fex-emu/RootFS}"
  rootfs_file="${rootfs_dir}/ArchLinux.sqsh"
  rootfs_tree="${rootfs_dir}/ArchLinux"
  mkdir -p "${rootfs_dir}"

  repair_rootfs_dir_before_fetch "${rootfs_dir}"

  if rootfs_dir_has_valid_candidate "${rootfs_dir}"; then
    echo "FEX Arch rootfs already exists; leaving it in place."
  else
    FEXRootFSFetcher -y -x --distro-name arch --distro-version rolling
  fi
  for candidate in "${rootfs_dir}" "${HOME}/.fex-emu/RootFS" "${HOME}/.local/share/fex-emu/RootFS"; do
    [[ -n "${candidate}" ]] || continue
    repair_rootfs_dir_before_fetch "${candidate}"
    if rootfs_dir_has_valid_candidate "${candidate}"; then
      rootfs_dir="${candidate}"
      rootfs_file="${rootfs_dir}/ArchLinux.sqsh"
      rootfs_tree="${rootfs_dir}/ArchLinux"
      break
    fi
  done
  if ! rootfs_dir_has_valid_candidate "${rootfs_dir}"; then
    echo "FEXRootFSFetcher did not install a valid Arch rootfs." >&2
    exit 1
  fi
  unpack_fex_rootfs_for_freedreno "${rootfs_dir}" "${rootfs_file}" "${rootfs_tree}"
  install_rocknix_guest_freedreno "${rootfs_dir}" "${rootfs_file}" "${rootfs_tree}"
else
  echo "FEXRootFSFetcher is missing from the installed FEX package." >&2
  exit 1
fi

if [[ -d "${rootfs_tree}" ]]; then
  ensure_canonical_fex_rootfs "ArchLinux" "${rootfs_tree}"
  write_fex_config_defaults "${legacy_config_dst}/Config.json" "${rootfs_tree}"
elif [[ -f "${rootfs_file}" ]]; then
  ensure_canonical_fex_rootfs "ArchLinux.sqsh" "${rootfs_file}"
  write_fex_config_defaults "${legacy_config_dst}/Config.json" "${rootfs_file}"
fi

fex_test_output="$(FEX /bin/uname -m 2>&1)" || {
  echo "FEX RootFS is installed, but FEX could not start an x86_64 process." >&2
  printf '%s\n' "${fex_test_output}" >&2
  echo "Check that squashfuse is installed and the user session can mount FUSE filesystems." >&2
  exit 1
}

if [[ "${fex_test_output}" != *x86_64* ]]; then
  echo "FEX RootFS is installed, but FEX could not start an x86_64 process." >&2
  printf '%s\n' "${fex_test_output}" >&2
  echo "Check that squashfuse is installed and the user session can mount FUSE filesystems." >&2
  exit 1
fi

echo "FEX is installed and a user RootFS is available."
