#!/usr/bin/env bash
set -euo pipefail

steam_root="${STEAM_STORAGE_ROOT:-${HOME}}/.local/share/Steam"
mode="${THORCH_STEAM_MODE:-bigpicture}"
use_gamescope="${THORCH_STEAM_USE_GAMESCOPE:-0}"
gamescope_width="${THORCH_STEAM_GAMESCOPE_WIDTH:-1920}"
gamescope_height="${THORCH_STEAM_GAMESCOPE_HEIGHT:-1080}"
gamescope_refresh="${THORCH_STEAM_GAMESCOPE_REFRESH:-60}"
gamescope_backend="${THORCH_STEAM_GAMESCOPE_BACKEND:-nested}"
mangohud="${THORCH_STEAM_MANGOHUD:-auto}"
mangohud_config="${THORCH_STEAM_MANGOHUD_CONFIG:-}"
support_bin_dir="${steam_root}/thorch-steamos-bin"
mangoapp_args=()
steam_system_dir="${THORCH_STEAM_SYSTEM_DIR:-/usr/share/steam}"
proton_arm_name="${THORCH_STEAM_PROTON_NAME:-Proton 11.0 (ARM64)}"
preflight="${THORCH_STEAM_PREFLIGHT:-1}"

runtime_lib_dir="$(find "${steam_root}/steam-runtime-steamrt-arm64" -path '*/files/lib/aarch64-linux-gnu' -type d -print -quit 2>/dev/null || true)"
runtime_bin_dir="$(find "${steam_root}/steam-runtime-steamrt-arm64" -path '*/pressure-vessel/bin' -type d -print -quit 2>/dev/null || true)"

configure_mangohud() {
  local config_dir config_file system_config user_config

  case "${mangohud,,}" in
    1|true|yes|on|enabled|auto|"")
      ;;
    0|false|no|off|disabled)
      ;;
    *)
      echo "Warning: ignoring unknown THORCH_STEAM_MANGOHUD value '${mangohud}'." >&2
      ;;
  esac

  unset MANGOHUD
  config_dir="${HOME}/.config/MangoHud"
  user_config="${config_dir}/MangoHud.conf"
  system_config=""
  if [[ -f /usr/share/thorch/mangohud/MangoHud.conf ]]; then
    system_config="/usr/share/thorch/mangohud/MangoHud.conf"
  elif [[ -f /etc/MangoHud.conf ]]; then
    system_config="/etc/MangoHud.conf"
  fi

  mkdir -p "${config_dir}"
  if [[ ! -f "${user_config}" && -n "${system_config}" ]]; then
    cp -f "${system_config}" "${user_config}"
  fi

  if [[ -n "${mangohud_config}" ]]; then
    config_file="${mangohud_config}"
  elif [[ -f "${user_config}" ]]; then
    config_file="${user_config}"
  else
    config_file=""
  fi

  [[ -f "${config_file}" && -w "${config_file}" ]] || return 0
  export MANGOHUD_CONFIGFILE="${config_file}"
  mangoapp_args=(--mangoapp)

  case "${mangohud,,}" in
    1|true|yes|on|enabled)
      if grep -q '^no_display' "${config_file}"; then
        sed -i 's/^no_display/# no_display/' "${config_file}"
      fi
      ;;
    0|false|no|off|disabled)
      if grep -q '^# *no_display' "${config_file}"; then
        sed -i 's/^# *no_display/no_display/' "${config_file}"
      elif ! grep -q '^no_display' "${config_file}"; then
        printf '\nno_display\n' >> "${config_file}"
      fi
      ;;
  esac
}

gamescope_supports_option() {
  local option="$1"
  gamescope --help 2>&1 | grep -q -- "${option}"
}

stage_proton_arm_manifest() {
  local proton_dir source_manifest

  source_manifest="${steam_system_dir}/toolmanifest.vdf"
  [[ -f "${source_manifest}" ]] || return 0

  proton_dir="${steam_root}/steamapps/common/${proton_arm_name}"
  mkdir -p "${proton_dir}"
  cp -f "${source_manifest}" "${proton_dir}/toolmanifest.vdf"
}

if [[ ! -x "${steam_root}/steamrtarm64/steam" ]]; then
  echo "Steam ARM64 is not installed. Run thorch-install-steam-arm64 first." >&2
  exit 1
fi

if [[ -x "${HOME}/.local/bin/thorch-setup-steam-arm64" ]]; then
  "${HOME}/.local/bin/thorch-setup-steam-arm64" --repair-proton-beta-runtime-links || true
elif command -v thorch-setup-steam-arm64 >/dev/null 2>&1; then
  thorch-setup-steam-arm64 --repair-proton-beta-runtime-links || true
fi
if [[ -x "${HOME}/.local/bin/thorch-repair-steam-arm64" ]]; then
  "${HOME}/.local/bin/thorch-repair-steam-arm64" || true
elif command -v thorch-repair-steam-arm64 >/dev/null 2>&1; then
  thorch-repair-steam-arm64 || true
fi

configure_mangohud
export LD_LIBRARY_PATH="${steam_root}/steamrtarm64:${steam_root}/steamrtarm64/video:${steam_root}/lib/aarch64-linux-gnu${runtime_lib_dir:+:${runtime_lib_dir}}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export PATH="${support_bin_dir}${runtime_bin_dir:+:${runtime_bin_dir}}:${PATH}"
export STEAM_BASE_FOLDER="${steam_root}"
export LANG="${LANG:-C.UTF-8}"
export LC_ALL="${LC_ALL:-C.UTF-8}"
cd "${steam_root}/steamrtarm64"

stage_proton_arm_manifest
case "${preflight,,}" in
  1|true|yes|on|enabled)
    ./steam -steamdeck -exitsteam || true
    stage_proton_arm_manifest
    ;;
esac

steam_bootstrap_args=(-noverifyfiles -nobootstrapupdate -skipinitialbootstrap -norepairfiles)
steam_args=()
case "${mode}" in
  desktop)
    steam_args=("${steam_bootstrap_args[@]}")
    ;;
  deck|gamepadui)
    steam_args=(-steamdeck -steamos3 -gamepadui "${steam_bootstrap_args[@]}")
    ;;
  bigpicture|*)
    steam_args=(-bigpicture "${steam_bootstrap_args[@]}")
    ;;
esac

if command -v gamescope >/dev/null 2>&1 && [[ "${use_gamescope}" == 1 ]]; then
  gamescope_args=(
    -W "${gamescope_width}"
    -H "${gamescope_height}"
    -r "${gamescope_refresh}"
    --xwayland-count 2
    -b
    -f
    "${mangoapp_args[@]}"
    -e
  )
  case "${gamescope_backend}" in
    auto|nested|"")
      ;;
    drm|sdl|wayland|headless|openvr)
      gamescope_args+=(--backend "${gamescope_backend}")
      ;;
    *)
      echo "Warning: ignoring unknown gamescope backend '${gamescope_backend}'." >&2
      ;;
  esac
  if [[ "${gamescope_backend}" == "drm" ]]; then
    if gamescope_supports_option "--use-rotation-shader"; then
      gamescope_args+=(--use-rotation-shader)
    fi
    exec env -u WAYLAND_DISPLAY gamescope "${gamescope_args[@]}" -- ./steam "${steam_args[@]}" "$@"
  fi
  exec gamescope "${gamescope_args[@]}" -- ./steam "${steam_args[@]}" "$@"
fi

exec ./steam "${steam_args[@]}" "$@"
