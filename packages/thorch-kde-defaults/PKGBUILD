# Maintainer: Thorch contributors

pkgname=thorch-kde-defaults
pkgver=1
pkgrel=12
pkgdesc='KDE Plasma Mobile/Desktop defaults for Thorch on AYN Thor'
arch=(aarch64)
url='https://github.com/ROCKNIX/distribution'
license=(GPL-2.0-or-later)
depends=(alsa-utils ark bluez bluez-utils bluedevil dolphin firefox gwenview kate kcalc kirigami konsole kscreen kwin libpulse noto-fonts-cjk okular perl pipewire plasma-desktop plasma-keyboard plasma-maliit-framework plasma-maliit-plugins plasma-mobile plasma-nm plasma-pa plasma-settings plasma-workspace plasma5support python qt6-declarative qt6-tools qt6-virtualkeyboard rtkit sddm spectacle systemd util-linux wireplumber xorg-xrandr)
optdepends=('vlc: media player')
install=thorch-kde-defaults.install
source=()
sha256sums=()

package() {
  cd "${startdir}/payload"
  cp -a . "${pkgdir}/"

  chmod 755 "${pkgdir}/usr/bin/thorch-audio-init"
  chmod 755 "${pkgdir}/usr/bin/thorch-display-setup"
  chmod 755 "${pkgdir}/usr/bin/thorch-hardware-settings"
  chmod 755 "${pkgdir}/usr/bin/thorch-touchscreen-setup"
  chmod 755 "${pkgdir}/usr/bin/thorch-kwin-touch-map"
  chmod 755 "${pkgdir}/usr/bin/thorch-sessionctl"
  chmod 755 "${pkgdir}/usr/bin/thorch-session-recovery"
  chmod 755 "${pkgdir}/usr/bin/thorch-switch-session"
  chmod 755 "${pkgdir}/etc/skel/.config/plasma-workspace/env/10-thorch-touch.sh"
  chmod 755 "${pkgdir}/etc/skel/Desktop/thorch-display-setup.desktop"
  chmod 755 "${pkgdir}/etc/skel/Desktop/thorch-switch-to-desktop.desktop"
  chmod 755 "${pkgdir}/etc/skel/Desktop/thorch-switch-to-mobile.desktop"
  chmod 755 "${pkgdir}/usr/share/applications/thorch-display-setup.desktop"

  install -d "${pkgdir}/etc/skel/.config/systemd/user/default.target.wants"
  ln -sf /usr/lib/systemd/user/thorch-audio-init.service \
    "${pkgdir}/etc/skel/.config/systemd/user/default.target.wants/thorch-audio-init.service"
}
