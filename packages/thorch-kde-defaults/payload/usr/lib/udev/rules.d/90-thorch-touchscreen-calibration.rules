# KDE/KWin maps absolute touch devices to a single output when WL_OUTPUT is set.
# The panels are mounted 90 degrees clockwise. Make that fixed hardware
# calibration a libinput default so output reconfiguration cannot reset it.
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT_TOUCHSCREEN}=="1", ENV{ID_PATH}=="platform-a90000.i2c", ENV{WL_OUTPUT}="DSI-2", ENV{LIBINPUT_CALIBRATION_MATRIX}="0 -1 1 1 0 0"
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT_TOUCHSCREEN}=="1", ENV{ID_PATH}=="platform-98c000.i2c", ENV{WL_OUTPUT}="DSI-1", ENV{LIBINPUT_CALIBRATION_MATRIX}="0 -1 1 1 0 0"
