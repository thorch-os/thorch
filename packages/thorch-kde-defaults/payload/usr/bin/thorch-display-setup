#!/usr/bin/env bash
set -euo pipefail

mode="${1:---reset}"
case "${mode}" in
	--initial)
		initial_setup=true
		;;
	--reset)
		initial_setup=false
		;;
	--help|-h)
		printf 'usage: thorch-display-setup [--initial|--reset]\n'
		exit 0
		;;
	*)
		printf 'usage: thorch-display-setup [--initial|--reset]\n' >&2
		exit 2
		;;
esac

export LC_ALL="${LC_ALL:-C.UTF-8}"
export DISPLAY="${DISPLAY:-:0}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"
if [[ -z "${WAYLAND_DISPLAY:-}" && -S "${XDG_RUNTIME_DIR}/wayland-0" ]]; then
	export WAYLAND_DISPLAY=wayland-0
fi

config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"
state_home="${XDG_STATE_HOME:-${HOME}/.local/state}"
initial_autostart="${config_home}/autostart/thorch-display-setup.desktop"
initial_marker="${state_home}/thorch/display-layout-v1.complete"

is_packaged_initial_autostart() {
	local expected

	[[ -f "${initial_autostart}" ]] || return 1
	expected='[Desktop Entry]
Type=Application
Name=Thorch Display Setup
Exec=/usr/bin/thorch-display-setup --initial
OnlyShowIn=KDE;
NoDisplay=true
X-KDE-autostart-phase=1'
	[[ "$(cat "${initial_autostart}")" == "${expected}" ]]
}

remove_packaged_initial_autostart() {
	if is_packaged_initial_autostart; then
		rm -f -- "${initial_autostart}"
	fi
}

complete_initial_setup() {
	local marker_dir temporary

	marker_dir="${initial_marker%/*}"
	install -d -m 0700 "${marker_dir}"
	temporary="$(mktemp "${initial_marker}.XXXXXX")"
	printf 'layout-v1\n' >"${temporary}"
	chmod 0600 "${temporary}"
	mv -f -- "${temporary}" "${initial_marker}"
	remove_packaged_initial_autostart
}

if [[ "${initial_setup}" == true && -f "${initial_marker}" ]]; then
	remove_packaged_initial_autostart
	exit 0
fi

kscreen_output_id() {
	local connector="$1"
	kscreen-doctor -o 2>/dev/null |
		sed -E 's/\x1b\[[0-9;]*m//g' |
		awk -v connector="${connector}" '$1 == "Output:" && $3 == connector {print $2; exit}'
}

apply_wayland_layout() {
	local dsi1 dsi2
	local dsi_scale=2
	local dsi1_logical_x=170
	local dsi1_logical_y=540

	command -v kscreen-doctor >/dev/null 2>&1 || {
		printf 'thorch-display-setup: kscreen-doctor is unavailable\n' >&2
		return 1
	}

	export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}"
	export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
	dsi2="$(kscreen_output_id DSI-2 || true)"
	dsi1="$(kscreen_output_id DSI-1 || true)"
	if [[ -z "${dsi2}" || -z "${dsi1}" ]]; then
		printf 'thorch-display-setup: both internal DSI outputs are not available\n' >&2
		return 1
	fi

	kscreen-doctor \
		"output.${dsi2}.enable" "output.${dsi2}.rotation.right" "output.${dsi2}.position.0,0" "output.${dsi2}.scale.${dsi_scale}" "output.${dsi2}.priority.1" \
		"output.${dsi1}.enable" "output.${dsi1}.rotation.right" "output.${dsi1}.position.${dsi1_logical_x},${dsi1_logical_y}" "output.${dsi1}.scale.${dsi_scale}" "output.${dsi1}.priority.2"

	if [[ -f "${HOME}/.config/kwinoutputconfig.json" ]]; then
		perl -0pi -e 's/"autoRotation": "InTabletMode"/"autoRotation": "Never"/g' "${HOME}/.config/kwinoutputconfig.json" || true
	fi

	command -v thorch-kwin-touch-map >/dev/null 2>&1 && thorch-kwin-touch-map || true
}

apply_x11_layout() {
	command -v xrandr >/dev/null 2>&1 || {
		printf 'thorch-display-setup: no supported display configuration backend is available\n' >&2
		return 1
	}

	xrandr --output DSI-2 --mode 1080x1920 --rotate right --pos 0x0 --primary \
	       --output DSI-1 --mode 1080x1240 --rotate right --pos 340x1080 \
	       --output DP-1 --off
	command -v thorch-kwin-touch-map >/dev/null 2>&1 && thorch-kwin-touch-map || true
}

if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
	apply_wayland_layout
	if [[ "${initial_setup}" == true ]]; then
		complete_initial_setup
	fi
	exit 0
fi

apply_x11_layout
if [[ "${initial_setup}" == true ]]; then
	complete_initial_setup
fi
