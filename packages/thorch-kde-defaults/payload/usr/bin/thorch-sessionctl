#!/usr/bin/env bash
set -euo pipefail

root_prefix="${THORCH_SESSIONCTL_ROOT:-}"
if [[ -n "${root_prefix}" ]]; then
  [[ "${root_prefix}" = /* && "${root_prefix}" != */../* && "${root_prefix}" != */.. ]] || {
    echo "THORCH_SESSIONCTL_ROOT must be an absolute path without parent traversal" >&2
    exit 2
  }
  root_prefix="${root_prefix%/}"
fi

state_dir="${root_prefix}/var/lib/thorch/session"
state_file="${state_dir}/state"
pending_file="${state_dir}/pending"
conf="${root_prefix}/etc/sddm.conf.d/90-thorch-local.conf"

usage() {
  cat >&2 <<'EOF'
usage:
  thorch-sessionctl set desktop|mobile|steamos|steamos-mobile|steamos-desktop [--user USER] [--reboot|--restart-display-manager|--stage|--no-restart]
  thorch-sessionctl status
  thorch-sessionctl recover

Session changes are staged in SDDM and applied by rebooting or restarting the
display manager. Reboot is preferred because Plasma/KWin often leaves stale
state behind when the display manager is restarted from inside the live session.
EOF
  exit 2
}

require_root() {
  [[ "${EUID}" -eq 0 || -n "${root_prefix}" ]] || {
    echo "thorch-sessionctl must run as root" >&2
    exit 1
  }
}

configured_user() {
  local user=""

  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    printf '%s\n' "${SUDO_USER}"
    return 0
  fi

  if [[ -n "${PKEXEC_UID:-}" ]]; then
    user="$(getent passwd "${PKEXEC_UID}" | cut -d: -f1 || true)"
    if [[ -n "${user}" && "${user}" != "root" ]]; then
      printf '%s\n' "${user}"
      return 0
    fi
  fi

  if [[ -f "${conf}" ]]; then
    user="$(awk -F= '/^User=/ {print $2; exit}' "${conf}")"
    if [[ -n "${user}" && "${user}" != "root" ]]; then
      printf '%s\n' "${user}"
      return 0
    fi
  fi

  printf 'thorch\n'
}

passwd_entry() {
  local lookup="$1"
  if [[ -n "${root_prefix}" ]]; then
    awk -F: -v lookup="${lookup}" \
      '$1 == lookup || $3 == lookup { print; found = 1; exit } END { exit !found }' \
      "${root_prefix}/etc/passwd"
  else
    getent passwd "${lookup}"
  fi
}

mode_session() {
  case "$1" in
    desktop|steamos-desktop)
      printf 'plasma.desktop\n'
      ;;
    mobile|steamos|steamos-mobile)
      printf 'plasma-mobile.desktop\n'
      ;;
    *)
      return 1
      ;;
  esac
}

mode_label() {
  case "$1" in
    desktop) printf 'Plasma Desktop\n' ;;
    mobile) printf 'Plasma Mobile\n' ;;
    steamos|steamos-mobile) printf 'Steam Mode with Plasma Mobile\n' ;;
    steamos-desktop) printf 'Steam Mode with Plasma Desktop\n' ;;
    *) return 1 ;;
  esac
}

mode_uses_steam() {
  case "$1" in
    steamos|steamos-mobile|steamos-desktop) return 0 ;;
    *) return 1 ;;
  esac
}

mode_uses_custom_action_drawer() {
  case "$1" in
    desktop|mobile|steamos|steamos-mobile|steamos-desktop) return 0 ;;
    *) return 1 ;;
  esac
}

write_sddm_autologin() {
  local user="$1" session="$2" tmp

  install -d -m 0755 "$(dirname "${conf}")"
  tmp="$(mktemp "${conf}.XXXXXX")"
  cat > "${tmp}" <<EOF
[Autologin]
User=${user}
Session=${session}
Relogin=true
EOF
  chmod 0644 "${tmp}"
  mv -f "${tmp}" "${conf}"
}

run_steamos_mode_for_user() {
  local user="$1" command="$2" home uid

  command -v thorch-steamos-mode >/dev/null 2>&1 || return 1
  home="$(getent passwd "${user}" | cut -d: -f6 || true)"
  uid="$(id -u "${user}" 2>/dev/null || true)"
  [[ -n "${home}" && -n "${uid}" ]] || return 1

  runuser -u "${user}" -- env \
    HOME="${home}" \
    XDG_RUNTIME_DIR="/run/user/${uid}" \
    /usr/bin/thorch-steamos-mode "${command}"
}

apply_mode_side_effects() {
  local mode="$1" user="$2"

  # A prefixed root is used by the package integration tests. Never mutate
  # services or user state outside that root in this mode.
  [[ -z "${root_prefix}" ]] || return 0

  if mode_uses_custom_action_drawer "${mode}"; then
    if [[ -x /usr/lib/thorch/plasma-mobile-action-drawer-mode ]]; then
      /usr/lib/thorch/plasma-mobile-action-drawer-mode enable || true
    fi
  else
    if [[ -x /usr/lib/thorch/plasma-mobile-action-drawer-mode ]]; then
      /usr/lib/thorch/plasma-mobile-action-drawer-mode disable || true
    fi
  fi

  if command -v thorch-steamos-mode >/dev/null 2>&1; then
    if mode_uses_steam "${mode}"; then
      run_steamos_mode_for_user "${user}" enable || {
        echo "warning: Steam mode is not installed or cannot be enabled for ${user}" >&2
      }
    else
      run_steamos_mode_for_user "${user}" disable || true
    fi
  fi
}

write_state() {
  local mode="$1" user="$2" session="$3"

  install -d -m 0755 "${state_dir}"
  cat > "${state_file}" <<EOF
mode=${mode}
user=${user}
session=${session}
updated=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
}

stage_pending() {
  local mode="$1" user="$2" session="$3"

  install -d -m 0755 "${state_dir}"
  cat > "${pending_file}" <<EOF
mode=${mode}
user=${user}
session=${session}
started=$(date -u +%Y-%m-%dT%H:%M:%SZ)
fallback=desktop
EOF
}

active_graphical_session_exists() {
  local sessions sid user seat tty details

  command -v loginctl >/dev/null 2>&1 || return 1
  sessions="$(loginctl list-sessions --no-legend 2>/dev/null || true)"
  [[ -n "${sessions}" ]] || return 1

  while read -r sid user seat tty rest; do
    [[ -n "${sid:-}" ]] || continue
    details="$(loginctl show-session "${sid}" -p State -p Type -p Class 2>/dev/null || true)"
    grep -qx 'State=active' <<< "${details}" || continue
    grep -qx 'Class=user' <<< "${details}" || continue
    grep -Eqx 'Type=(wayland|x11)' <<< "${details}" || continue
    return 0
  done <<< "${sessions}"

  return 1
}

set_mode() {
  local mode="" user="" restart="none" session label

  [[ "$#" -gt 0 ]] || usage
  mode="$1"
  shift

  session="$(mode_session "${mode}")" || usage
  label="$(mode_label "${mode}")" || usage
  user="$(configured_user)"

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --user)
        [[ -n "${2:-}" ]] || usage
        user="$2"
        shift 2
        ;;
      --reboot)
        restart="reboot"
        shift
        ;;
      --restart-display-manager)
        restart="display-manager"
        shift
        ;;
      --stage)
        restart="stage"
        shift
        ;;
      --no-restart)
        restart="none"
        shift
        ;;
      *)
        usage
        ;;
    esac
  done

  require_root
  passwd_entry "${user}" >/dev/null || {
    echo "unknown session user: ${user}" >&2
    exit 1
  }
  if [[ ! -f "${root_prefix}/usr/share/wayland-sessions/${session}" && ! -f "${root_prefix}/usr/share/xsessions/${session}" ]]; then
    echo "${label} is not installed. Install the matching Plasma package first." >&2
    exit 1
  fi

  write_sddm_autologin "${user}" "${session}"
  apply_mode_side_effects "${mode}" "${user}"
  write_state "${mode}" "${user}" "${session}"

  if [[ "${restart}" != "none" ]]; then
    stage_pending "${mode}" "${user}" "${session}"
  else
    rm -f "${pending_file}"
  fi

  echo "Configured ${label} for ${user}."

  case "${restart}" in
    reboot)
      echo "Rebooting to apply session cleanly..."
      systemctl reboot
      ;;
    display-manager)
      echo "Restarting display manager..."
      systemctl restart display-manager.service
      ;;
    stage)
      echo "Session switch is staged for the next reboot."
      ;;
  esac
}

status_mode() {
  if [[ -f "${state_file}" ]]; then
    cat "${state_file}"
  else
    echo "mode=unknown"
  fi

  if [[ -f "${pending_file}" ]]; then
    echo "pending=yes"
    sed 's/^/pending_/' "${pending_file}"
  else
    echo "pending=no"
  fi
}

recover_mode() {
  require_root

  [[ -f "${pending_file}" ]] || exit 0
  sleep "${THORCH_SESSION_RECOVERY_DELAY:-75}"

  if active_graphical_session_exists; then
    rm -f "${pending_file}"
    exit 0
  fi

  echo "No active graphical session appeared after a Thorch mode switch; falling back to Plasma Desktop." >&2
  set_mode desktop --no-restart
  rm -f "${pending_file}"
  systemctl restart display-manager.service || true
}

cmd="${1:-}"
case "${cmd}" in
  set)
    shift
    set_mode "$@"
    ;;
  status)
    status_mode
    ;;
  recover)
    recover_mode
    ;;
  *)
    usage
    ;;
esac
